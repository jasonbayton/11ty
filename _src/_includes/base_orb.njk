<!DOCTYPE html>
<html lang="en">
    <head>
        {% include "./_parts/head.njk" %}
    </head>
    <body>
        <!-- Floating nav toggle — always visible -->
        <button id="orb-nav-toggle" type="button" aria-label="Show navigation">
            <span class="material-symbols-outlined" id="orb-nav-icon" style="font-size:14px">expand_content</span>
        </button>

        <header class="home-redesign-header orb-header-hidden" id="orb-header">
            {% include "./_parts/header.njk" %}
        </header>
        <content id="orb-page">
            <style>
                /* ---- Hidden header/footer ---- */
                .orb-header-hidden,
                .orb-footer-hidden {
                    max-height: 0;
                    overflow: hidden;
                    opacity: 0;
                    pointer-events: none;
                    transition: max-height 0.4s ease, opacity 0.3s ease;
                }
                .orb-header-visible {
                    max-height: 500px;
                    opacity: 1;
                    pointer-events: auto;
                }
                .orb-footer-visible {
                    max-height: 1000px;
                    opacity: 1;
                    pointer-events: auto;
                }

                /* Floating nav button */
                #orb-nav-toggle {
                    position: fixed;
                    top: 0.5rem;
                    left: 0.5rem;
                    z-index: 10001;
                    width: 28px;
                    height: 28px;
                    border-radius: 50%;
                    border: 1px solid var(--border-color, rgba(0,0,0,0.12));
                    background: var(--card-bg, #fff);
                    color: var(--main-text, #1f2937);
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                    transition: transform 0.2s ease, background 0.2s ease;
                }
                #orb-nav-toggle:hover {
                    transform: scale(1.08);
                    background: var(--main-orange, #ff4500);
                    color: #fff;
                    border-color: var(--main-orange, #ff4500);
                }
                [data-theme="dark"] #orb-nav-toggle {
                    background: rgba(255, 255, 255, 0.08);
                    border-color: rgba(255, 255, 255, 0.12);
                    color: #e5e7eb;
                }
                [data-theme="dark"] #orb-nav-toggle:hover {
                    background: var(--main-orange, #ff4500);
                    color: #fff;
                }

                /* ---- Orb page layout ---- */
                #orb-page {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    padding: 4rem 1rem 10rem;
                    min-height: 60vh;
                }

                /* ---- Title — matches site hero style ---- */
                .orb-title {
                    font-family: 'Open Sans', sans-serif;
                    font-size: clamp(28px, 4vw, 48px);
                    font-weight: 800;
                    line-height: 1.1;
                    color: var(--main-text);
                    text-align: center;
                    margin: 0 0 0.5rem;
                    padding: 0 1rem;
                }

                .orb-subtitle {
                    font-size: 0.85rem;
                    font-weight: 400;
                    color: var(--secondary-text, #9ca3af);
                    text-align: center;
                    margin: 0 0 1rem;
                    letter-spacing: 0.04em;
                    text-transform: uppercase;
                }

                /* ---- Canvas container ---- */
                .orb-container {
                    position: relative;
                    width: 280px;
                    height: 280px;
                    margin: 0 auto 0.5rem;
                }
                @media (min-width: 640px) {
                    .orb-container {
                        width: 380px;
                        height: 380px;
                    }
                }
                #orb-canvas {
                    display: block;
                    width: 100%;
                    height: 100%;
                }

                /* ---- Mic button ---- */
                .orb-mic-wrap {
                    display: flex;
                    justify-content: center;
                    margin-bottom: 2rem;
                }
                #orb-mic-btn {
                    width: 48px;
                    height: 48px;
                    border-radius: 50%;
                    border: 2px solid var(--main-orange, #ff4500);
                    background: transparent;
                    color: var(--main-orange, #ff4500);
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    transition: all 0.2s ease;
                    position: relative;
                }
                #orb-mic-btn:hover {
                    background: rgba(255, 69, 0, 0.1);
                }
                #orb-mic-btn.orb-mic-active {
                    background: var(--main-orange, #ff4500);
                    color: #fff;
                    animation: orb-mic-pulse 1.5s ease-in-out infinite;
                }
                @keyframes orb-mic-pulse {
                    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 69, 0, 0.4); }
                    50% { box-shadow: 0 0 0 12px rgba(255, 69, 0, 0); }
                }

                /* ---- Chat area ---- */
                .orb-chat {
                    width: 100%;
                    max-width: 800px;
                    margin: 0.5rem auto 0;
                    padding: 0 1rem;
                    box-sizing: border-box;
                }
                #orb-messages {
                    max-height: 400px;
                    overflow-y: auto;
                    padding: 0.5rem 0;
                    margin-bottom: 0.75rem;
                    display: flex;
                    flex-direction: column;
                    gap: 0.75rem;
                }
                .orb-msg { display: flex; flex-direction: column; }
                .orb-msg-user { align-items: flex-end; }
                .orb-msg-assistant { align-items: flex-start; }
                .orb-bubble {
                    max-width: 100%;
                    padding: 0.6rem 0.9rem;
                    border-radius: 1rem;
                    font-size: 0.9rem;
                    line-height: 1.5;
                    word-break: break-word;
                }
                .orb-bubble-user {
                    max-width: 85%;
                }
                .orb-bubble a {
                    color: var(--main-orange, #ff4500);
                    text-decoration: underline;
                }
                .orb-bubble-user {
                    background: var(--main-orange, #ff4500);
                    color: #fff;
                    border-bottom-right-radius: 0.3rem;
                }
                .orb-bubble-assistant {
                    background: var(--card-bg, #f3f4f6);
                    color: var(--main-text, #1f2937);
                    border-bottom-left-radius: 0.3rem;
                }
                [data-theme="dark"] .orb-bubble-assistant {
                    background: rgba(255, 255, 255, 0.06);
                    color: #e5e7eb;
                }
                .orb-sources {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 0.4rem;
                    margin-top: 0.3rem;
                    padding-left: 0.5rem;
                }
                .orb-sources a {
                    font-size: 0.75rem;
                    color: var(--main-blue, #0283bd);
                    text-decoration: none;
                    background: rgba(2, 131, 189, 0.08);
                    padding: 0.15rem 0.5rem;
                    border-radius: 0.75rem;
                }
                .orb-sources a:hover { text-decoration: underline; }

                /* Typing indicator */
                .orb-dot {
                    display: inline-block;
                    width: 6px;
                    height: 6px;
                    border-radius: 50%;
                    background: #9ca3af;
                    margin: 0 2px;
                    animation: orb-bounce 1.2s infinite;
                }
                .orb-dot:nth-child(2) { animation-delay: 0.15s; }
                .orb-dot:nth-child(3) { animation-delay: 0.3s; }
                @keyframes orb-bounce {
                    0%, 80%, 100% { transform: translateY(0); }
                    40% { transform: translateY(-6px); }
                }

                /* ---- Input bar (original orb style) ---- */
                .orb-input-bar {
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                    background: var(--card-bg, #f9fafb);
                    border: 1px solid var(--border-color, #e5e7eb);
                    border-radius: 0.75rem;
                    padding: 0.5rem 0.75rem;
                }
                [data-theme="dark"] .orb-input-bar {
                    background: rgba(255, 255, 255, 0.04);
                    border-color: rgba(255, 255, 255, 0.1);
                }
                #orb-input {
                    flex: 1;
                    border: none;
                    background: transparent;
                    font-size: 0.9rem;
                    color: var(--main-text, #1f2937);
                    outline: none;
                    min-width: 0;
                }
                #orb-input::placeholder {
                    color: #9ca3af;
                }
                [data-theme="dark"] #orb-input {
                    color: #fff;
                }
                #orb-send-btn {
                    border: none;
                    background: transparent;
                    color: var(--main-orange, #ff4500);
                    cursor: pointer;
                    padding: 0.25rem;
                    display: flex;
                    align-items: center;
                    flex-shrink: 0;
                }
                #orb-send-btn:disabled {
                    opacity: 0.3;
                    cursor: not-allowed;
                }

                /* ---- Recent questions ---- */
                #orb-recent-questions {
                    margin-top: 1.5rem;
                    text-align: center;
                }
                #orb-recent-questions h3 {
                    font-size: 0.8rem;
                    text-transform: uppercase;
                    letter-spacing: 0.05em;
                    color: var(--secondary-text, #9ca3af);
                    margin: 0 0 0.5rem;
                }
                .orb-recent-list {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 0.4rem;
                    justify-content: center;
                }
                .orb-recent-item {
                    font-size: 0.8rem;
                    background: rgba(255, 69, 0, 0.06);
                    color: var(--main-orange, #ff4500);
                    border: 1px solid rgba(255, 69, 0, 0.15);
                    border-radius: 1rem;
                    padding: 0.3rem 0.75rem;
                    cursor: pointer;
                    transition: background 0.15s;
                }
                .orb-recent-item:hover {
                    background: rgba(255, 69, 0, 0.12);
                }
            </style>

            <h1 class="orb-title">Ask MIKA anything about Android Enterprise</h1>
            <p class="orb-subtitle">MIKA - Mobile Intelligence & Knowledge Assistant</p>

            <div class="orb-container">
                <canvas id="orb-canvas"></canvas>
            </div>

            <div class="orb-mic-wrap">
                <button id="orb-mic-btn" aria-label="Start voice input" type="button">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                        <line x1="12" y1="19" x2="12" y2="23"/>
                        <line x1="8" y1="23" x2="16" y2="23"/>
                    </svg>
                </button>
            </div>

            <div class="orb-chat">
                <div id="orb-messages"></div>
                <div class="orb-input-bar">
                    <input id="orb-input" type="text" placeholder="Ask a question..." autocomplete="off">
                    <button id="orb-send-btn" type="button" aria-label="Send message">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                        </svg>
                    </button>
                </div>

                <div id="orb-recent-questions" style="display:none">
                    <h3>Others have asked</h3>
                    <div class="orb-recent-list"></div>
                </div>
            </div>
        </content>
        <footer class="orb-footer-hidden" id="orb-footer" style="margin-top: 100px;">
            {% include "./_parts/footer.njk" %}
        </footer>
        <script src="/js/orb-chat.js" defer></script>
        <script>
        (function () {
            var toggle = document.getElementById('orb-nav-toggle');
            var icon = document.getElementById('orb-nav-icon');
            var header = document.getElementById('orb-header');
            var footer = document.getElementById('orb-footer');
            var open = false;

            toggle.addEventListener('click', function () {
                open = !open;
                if (open) {
                    header.classList.remove('orb-header-hidden');
                    header.classList.add('orb-header-visible');
                    footer.classList.remove('orb-footer-hidden');
                    footer.classList.add('orb-footer-visible');
                    icon.textContent = 'collapse_content';
                } else {
                    header.classList.add('orb-header-hidden');
                    header.classList.remove('orb-header-visible');
                    footer.classList.add('orb-footer-hidden');
                    footer.classList.remove('orb-footer-visible');
                    icon.textContent = 'expand_content';
                }
            });
        })();
        </script>
    </body>
</html>
