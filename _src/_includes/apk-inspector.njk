<!DOCTYPE html>
<html lang="en">
    <head>
        <!-- head/meta goes here -->
        {% include "./_parts/head.njk" %}
        <!-- // -->
    </head>
    <body>
        <header>
            <!-- Header goes here -->
            {% include "./_parts/header.njk" %}
            <!-- // -->
        </header>
        <content id="generator">
            <section id="page_content">
                <div id="qr_type" class="padding-bottom-10">
                    <a class="button button-small" href="/qr-generator">AMAPI</a>
                    <a class="button button-small" href="/qr-generator-dpc">Custom DPC</a>
                    <a class="button button-small" href="/zt-generator">ZT DPC extras</a>
                    <a class="button button-small active" href="/apk-inspector">APK inspector</a>
                </div>
                <div class="section-title base-title">
                    {{ title }}
                </div>
                {% if alert %}
                <div class="callout callout-small">
                    <p><span class="material-symbols-outlined">quick_reference</span> {{ alert | safe }}</p>
                </div>
                {% endif %}

                {{ content | safe }}

                <style>
                    /* Scoped APK-inspector UI (page-local, themed via core.css vars). */
                    .apk-drop {
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        gap: 8px;
                        text-align: center;
                        padding: 48px 20px;
                        cursor: pointer;
                        border: 2px dashed var(--light);
                        border-radius: 14px;
                        background: var(--subtle-bg);
                        color: var(--text);
                        transition: border-color .15s ease, background .15s ease, transform .15s ease;
                    }
                    .apk-drop:hover { border-color: var(--orange); }
                    .apk-drop.apk-drag {
                        border-color: var(--orange);
                        background: var(--orange-opacity);
                        transform: scale(1.01);
                    }
                    .apk-drop-icon { font-size: 52px; color: var(--orange); }
                    .apk-drop-title { font-weight: 600; font-size: 1.15em; }
                    .apk-drop-sub { font-size: .85em; opacity: .7; max-width: 36ch; }
                    .apk-visually-hidden {
                        position: absolute;
                        width: 1px; height: 1px;
                        padding: 0; margin: -1px;
                        overflow: hidden; clip: rect(0 0 0 0);
                        white-space: nowrap; border: 0;
                    }

                    /* Card/chip surface tokens (core.css has no card/shadow tokens;
                       these mirror the redesign mockup and follow the site's theme). */
                    :root {
                        --apk-card: #f7f7f7; --apk-border: #e2e2e2; --apk-line: #ececec;
                        --apk-shadow: 0 1px 2px rgba(0,0,0,.05), 0 8px 24px rgba(0,0,0,.06);
                    }
                    @media (prefers-color-scheme: dark) {
                        :root {
                            --apk-card: #161616; --apk-border: #2d2d2d; --apk-line: #262626;
                            --apk-shadow: 0 1px 2px rgba(0,0,0,.5), 0 10px 30px rgba(0,0,0,.55);
                        }
                    }
                    :root[data-theme="dark"] {
                        --apk-card: #161616; --apk-border: #2d2d2d; --apk-line: #262626;
                        --apk-shadow: 0 1px 2px rgba(0,0,0,.5), 0 10px 30px rgba(0,0,0,.55);
                    }
                    :root[data-theme="light"] {
                        --apk-card: #f7f7f7; --apk-border: #e2e2e2; --apk-line: #ececec;
                        --apk-shadow: 0 1px 2px rgba(0,0,0,.05), 0 8px 24px rgba(0,0,0,.06);
                    }

                    /* Dropzone wrapper: spacing only, no solid box, so the dashed
                       dropzone / loaded bar stand alone (core.css .generator-bg would
                       otherwise wrap them in a padded subtle-bg panel). */
                    .apk-dropwrap { margin: 15px 0; }

                    /* Loaded-file bar (replaces the dropzone once a file is picked). */
                    .apk-drop-loaded {
                        display: flex; align-items: center; gap: 14px;
                        border: 2px dashed var(--apk-border); border-radius: 14px;
                        background: var(--subtle-bg); padding: 14px 18px; font-size: 16px;
                    }
                    /* display:flex above would otherwise defeat the hidden attribute. */
                    .apk-drop[hidden], .apk-drop-loaded[hidden] { display: none; }
                    .apk-loaded-ico {
                        flex: none; width: 42px; height: 42px; max-width: none; border-radius: 10px;
                        display: grid; place-items: center; font-size: 24px;
                        background: color-mix(in srgb, var(--orange) 14%, transparent); color: var(--orange);
                    }
                    .apk-loaded-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
                    .apk-loaded-name { font-family: monospace; font-size: .9em; color: var(--orange); word-break: break-all; }
                    .apk-loaded-meta { font-size: .8em; opacity: .7; }
                    .apk-loaded-again {
                        margin-left: auto; flex: none; font-size: .85em;
                        color: var(--text); border: 1px solid var(--apk-border); background: var(--apk-card);
                        padding: 8px 14px; border-radius: 9px; cursor: pointer;
                        transition: border-color .15s ease, color .15s ease;
                    }
                    .apk-loaded-again:hover { border-color: var(--orange); color: var(--orange); }

                    /* Results baseline: reset to 16px so the component scale matches the
                       redesign (body is 20px), and neutralise core.css's orange <code>. */
                    #apk_results { font-size: 16px; line-height: 1.5; }
                    #apk_results code { color: var(--text); overflow-x: visible; overflow-wrap: anywhere; }
                    .apk-kv .apk-strong, .apk-kv .apk-strong code { font-weight: 600; }


                    /* Summary chips */
                    .apk-chips { display: flex; flex-wrap: wrap; gap: 8px; margin: 4px 0 18px; }
                    .apk-chip {
                        display: inline-flex; align-items: center; gap: 5px;
                        font-size: .78em; font-weight: 600; line-height: 1.4;
                        padding: 4px 10px; border-radius: 999px;
                        border: 1px solid var(--apk-border); background: var(--apk-card); color: var(--text);
                    }
                    .apk-chip .material-symbols-outlined { font-size: 15px; }
                    .apk-chip .k { opacity: .6; font-weight: 500; }
                    .apk-chip-good { color: var(--main-green); background: color-mix(in srgb, var(--main-green) 15%, transparent); border-color: color-mix(in srgb, var(--main-green) 45%, transparent); }
                    .apk-chip-warn { color: var(--orange); background: color-mix(in srgb, var(--orange) 15%, transparent); border-color: color-mix(in srgb, var(--orange) 48%, transparent); }
                    .apk-chip-info { color: var(--main-blue); background: color-mix(in srgb, var(--main-blue) 14%, transparent); border-color: color-mix(in srgb, var(--main-blue) 42%, transparent); }

                    /* Card grid: two equal columns that fill the width; wide cards
                       span both. (auto-fit left empty tracks on wide layouts.) */
                    .apk-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
                    @media (max-width: 640px) { .apk-grid { grid-template-columns: 1fr; } }
                    .apk-card {
                        background: var(--apk-card); border: 1px solid var(--apk-border);
                        border-radius: 14px; padding: 2px 18px 10px; box-shadow: var(--apk-shadow);
                    }
                    .apk-card-wide { grid-column: 1 / -1; }
                    .apk-card-head {
                        display: flex; align-items: center; gap: 10px;
                        padding: 14px 0 12px; border-bottom: 1px solid var(--apk-line);
                    }
                    .apk-card-badge {
                        flex: none; width: 30px; height: 30px; max-width: none; border-radius: 8px;
                        display: grid; place-items: center; font-size: 19px;
                        background: color-mix(in srgb, var(--orange) 14%, transparent); color: var(--orange);
                    }
                    .apk-card-head h2 { font-size: 1em; font-weight: 700; margin: 0; }
                    .apk-card-count {
                        margin-left: auto; font-size: .74em; font-weight: 700; color: #fff;
                        background: var(--main-blue); padding: 2px 9px; border-radius: 999px;
                    }

                    /* Key/value rows */
                    .apk-kv { display: grid; grid-template-columns: minmax(104px, 34%) minmax(0, 1fr); margin: 0; }
                    .apk-row { display: contents; }
                    .apk-card .apk-kv dt {
                        padding: 9px 12px 9px 0; margin: 0; font-size: .82em; opacity: .72;
                        border-bottom: 1px solid var(--apk-line);
                        /* plain block: stretches to row height (borders align) while the
                           label text still flows/wraps inline (flex broke inline links). */
                    }
                    .apk-card .apk-kv dd {
                        margin: 0; padding: 9px 0; border-bottom: 1px solid var(--apk-line);
                        min-width: 0; font-size: .88em; overflow-wrap: anywhere; line-height: 1.55;
                    }
                    /* Inline chips/pills/copy sit on the value's baseline row. */
                    .apk-kv dd .label, .apk-kv dd .apk-chip { vertical-align: middle; }
                    .apk-row:last-child dt, .apk-row:last-child dd { border-bottom: none; }
                    .apk-kv code { font-family: monospace; font-size: .92em; word-break: break-all; }
                    .apk-kv a.label { text-decoration: none; }

                    /* Permissions */
                    .apk-perms {
                        list-style: none; margin: 12px 0 4px; padding: 0;
                        display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 4px 18px;
                    }
                    .apk-perms li { padding: 5px 0; border-bottom: 1px solid var(--apk-line); }
                    .apk-perms code { font-family: monospace; font-size: .82em; word-break: break-all; }

                    @media (max-width: 640px) {
                        .apk-kv { grid-template-columns: 1fr; }
                        .apk-card .apk-kv dt { padding-bottom: 0; border-bottom: none; }
                        .apk-card .apk-kv dd { padding-top: 2px; }
                        .apk-row dt { padding-top: 10px; }
                        /* Loaded bar: let the button drop to its own row so the
                           filename gets the full width instead of being crushed. */
                        .apk-drop-loaded { flex-wrap: wrap; }
                        .apk-loaded-text { flex: 1 1 0; }
                        .apk-loaded-again { margin-left: 0; flex-basis: 100%; }
                    }
                </style>

                <div class="apk-dropwrap">
                    <label for="apk_file" id="apk_dropzone" class="apk-drop">
                        <span class="material-symbols-outlined apk-drop-icon">upload_file</span>
                        <span class="apk-drop-title">Drop an APK here</span>
                        <span class="apk-drop-sub">or click to choose a file. Read in your browser, nothing is uploaded</span>
                    </label>
                    <div id="apk_loaded" class="apk-drop-loaded" hidden>
                        <span class="material-symbols-outlined apk-loaded-ico">upload_file</span>
                        <div class="apk-loaded-text">
                            <span class="apk-loaded-name" id="apk_loaded_name"></span>
                            <span class="apk-loaded-meta" id="apk_loaded_meta"></span>
                        </div>
                        <button type="button" class="apk-loaded-again" id="apk_inspect_another">Inspect another</button>
                    </div>
                    <input type="file" id="apk_file" class="apk-visually-hidden" accept=".apk,application/vnd.android.package-archive">
                </div>

                <div id="error_message" style="color: red; margin-top: 10px;"></div>

                <div class="post-block" id="apk_results"></div>

                <div class="changelog-qr-generator">
                    {% include "./_parts/gitlog.njk" %}
                </div>
            </section>
            <!-- Page feedback goes here -->
            {% include "./_parts/feedback.njk" %}
            <!-- // -->
        </content>
        <footer>
            {% include "./_parts/footer.njk" %}
            <!-- API level -> Android version map, injected from _data/android_versions.json
                 (same source as /api/android_versions.json) so SDK tags never drift. -->
            <script>
                window.APK_ANDROID_VERSIONS = {
                {%- for v in android_versions.items %}
                    "{{ v.apiLevel }}": { "name": {{ v.version | dump | safe }}, "codename": {{ v.codename | dump | safe }} }{% if not loop.last %},{% endif %}
                {%- endfor %}
                };
            </script>
            <script src="/js/apk-inspector.js"></script>
        </footer>
        {% include "./_parts/mika-widget.njk" %}
    </body>
</html>
