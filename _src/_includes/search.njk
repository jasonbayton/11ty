<!DOCTYPE html>
<html lang="en">
    <head>
        <!-- head/meta goes here -->
        {% include "./_parts/head.njk" %}
        <!-- // -->
    </head>
    <body>
        <header>
            <!-- Header goes here -->
            {% include "./_parts/header.njk" %}
            <!-- // -->
        </header>
        <content id="search">
            <section id="page_content">
                <div class="section-title base-title">
                    {{ title }}
                </div>

                {{ content | safe }}

                <div  id="search-field" class="field">
                    <input type="search" placeholder="Type a word to begin.." id="searchField">
                    <button type="button" id="search-clear" aria-label="Clear search" hidden><span class="material-symbols-outlined">close</span></button>
                </div>

                <div class="post-block search-results" id="searchResults"></div>

                <div class="mika-search-cta">
                    <p>Can't find what you're looking for? <a href="/mika/" id="mika-search-link">Ask MIKA</a> - the AI-powered assistant with full access to bayton.org content.</p>
                </div>
                <style>
                    .mika-search-cta {
                        margin-top: 2rem;
                        margin-bottom: 3rem;
                        padding: 1rem 1.25rem;
                        border-radius: 0.75rem;
                        background: rgba(255, 69, 0, 0.05);
                        border: 1px solid rgba(255, 69, 0, 0.15);
                        text-align: center;
                        font-size: 0.85rem;
                        color: var(--text, #cfcfcf);
                    }
                    .mika-search-cta a {
                        color: var(--main-orange, #ff4500);
                        font-weight: 600;
                        text-decoration: none;
                    }
                    .mika-search-cta a:hover {
                        text-decoration: underline;
                    }
                </style>
            </section>
            <!-- Page feedback goes here -->
            {% include "./_parts/feedback.njk" %}
            <!-- // -->
        </content>
        <footer>
            {% include "./_parts/footer.njk" %}
        </footer>
        <script defer type="text/javascript" src="/js/fuse-search.js"></script>
        <script>
            (function () {
                var searchField = document.getElementById("searchField");
                var mikaLink = document.getElementById("mika-search-link");

                function updateMikaLink() {
                    var baseUrl = "/mika/";
                    var query = searchField && typeof searchField.value === "string" ? searchField.value.trim() : "";

                    if (!mikaLink) {
                        return;
                    }

                    mikaLink.href = query ? baseUrl + "?q=" + encodeURIComponent(query) : baseUrl;
                }

                if (!searchField || !mikaLink) {
                    return;
                }

                searchField.addEventListener("input", updateMikaLink);
                updateMikaLink();
            })();
        </script>
        {% include "./_parts/mika-widget.njk" %}
    </body>
</html>
