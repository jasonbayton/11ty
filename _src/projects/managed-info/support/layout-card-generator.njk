/* ── STATE ───────────────────────────────────────────────── */
const S = {
  spec: null,
  sel: null,        // selected path (array) or null
  dark: false,
  pw: 360,          // preview width px
  collapsed: new Set(),   // path keys of collapsed tree nodes
  secState: {},           // section key -> bool (true=open)
};

/* ── PATH HELPERS ────────────────────────────────────────── */
const pk = p => JSON.stringify(p);

function gn(root, path) {
  let n = root;
  for (const i of path) {
    if (!n || !n.children || i >= n.children.length) return null;
    n = n.children[i];
  }
  return n;
}

function delNode(root, path) {
  if (!path.length) return null;
  const par = gn(root, path.slice(0, -1));
  if (!par || !par.children) return root;
  par.children.splice(path[path.length - 1], 1);
  if (!par.children.length) delete par.children;
  return root;
}

function addChild(root, pPath, type) {
  const par = gn(root, pPath);
  if (!par) return null;
  if (!par.children) par.children = [];
  par.children.push({ type });
  return [...pPath, par.children.length - 1];
}

function moveNode(root, path, dir) {
  if (!path.length) return null;
  const pp = path.slice(0, -1);
  const par = gn(root, pp);
  if (!par || !par.children) return null;
  const i = path[path.length - 1], j = i + dir;
  if (j < 0 || j >= par.children.length) return null;
  [par.children[i], par.children[j]] = [par.children[j], par.children[i]];
  return [...pp, j];
}

/* ── COLOUR ─────────────────────────────────────────────── */
function toCSS(hex) {
  if (!hex || typeof hex !== 'string') return null;
  const h = hex.replace('#', '');
  if (h.length === 8) {
    const a = parseInt(h.slice(0,2), 16) / 255;
    const r = parseInt(h.slice(2,4), 16);
    const g = parseInt(h.slice(4,6), 16);
    const b = parseInt(h.slice(6,8), 16);
    return 'rgba(' + r + ',' + g + ',' + b + ',' + a.toFixed(3) + ')';
  }
  return hex;
}

/* ── PREVIEW CONSTANTS ───────────────────────────────────── */
const ARR = {
  top:'flex-start', start:'flex-start', center:'center', centre:'center',
  bottom:'flex-end', end:'flex-end', right:'flex-end',
  space_between:'space-between', space_around:'space-around', space_evenly:'space-evenly',
};
const CA = {
  top_start:'start start', top_center:'start center', top_end:'start end',
  center_start:'center start', center:'center center', center_end:'center end',
  bottom_start:'end start', bottom_center:'end center', bottom_end:'end end',
};
const SC = {
  crop:'cover', fit:'contain', fill_bounds:'fill',
  fill_width:'cover', fill_height:'cover', inside:'scale-down', none:'none',
};
const TYP = {
  displayLarge:  {fs:'57px',fw:'400',ls:'-0.25px',lh:'64px'},
  displayMedium: {fs:'45px',fw:'400',ls:'0px',    lh:'52px'},
  displaySmall:  {fs:'36px',fw:'400',ls:'0px',    lh:'44px'},
  headlineLarge: {fs:'32px',fw:'400',ls:'0px',    lh:'40px'},
  headlineMedium:{fs:'28px',fw:'400',ls:'0px',    lh:'36px'},
  headlineSmall: {fs:'24px',fw:'400',ls:'0px',    lh:'32px'},
  titleLarge:    {fs:'22px',fw:'400',ls:'0px',    lh:'28px'},
  titleMedium:   {fs:'16px',fw:'500',ls:'0.15px', lh:'24px'},
  titleSmall:    {fs:'14px',fw:'500',ls:'0.10px', lh:'20px'},
  bodyLarge:     {fs:'16px',fw:'400',ls:'0.50px', lh:'24px'},
  bodyMedium:    {fs:'14px',fw:'400',ls:'0.25px', lh:'20px'},
  bodySmall:     {fs:'12px',fw:'400',ls:'0.40px', lh:'16px'},
  labelLarge:    {fs:'14px',fw:'500',ls:'0.10px', lh:'20px'},
  labelMedium:   {fs:'12px',fw:'500',ls:'0.50px', lh:'16px'},
  labelSmall:    {fs:'11px',fw:'500',ls:'0.50px', lh:'16px'},
};
const FW = {light:'300', medium:'500', semi_bold:'600', semibold:'600', bold:'700'};

function applyBase(el, n) {
  if (n.fillMaxWidth) el.style.width = '100%';
  if (n.fillMaxHeight) el.style.height = '100%';
  if (n.widthDp != null) el.style.width = n.widthDp + 'px';
  if (n.heightDp != null) el.style.height = n.heightDp + 'px';
  if (n.minWidthDp != null) el.style.minWidth = n.minWidthDp + 'px';
  if (n.maxWidthDp != null) el.style.maxWidth = n.maxWidthDp + 'px';
  if (n.minHeightDp != null) el.style.minHeight = n.minHeightDp + 'px';
  const pt = n.paddingTopDp    ?? n.paddingVerticalDp   ?? n.paddingDp ?? 0;
  const pr = n.paddingEndDp    ?? n.paddingHorizontalDp ?? n.paddingDp ?? 0;
  const pb = n.paddingBottomDp ?? n.paddingVerticalDp   ?? n.paddingDp ?? 0;
  const pl = n.paddingStartDp  ?? n.paddingHorizontalDp ?? n.paddingDp ?? 0;
  if (pt || pr || pb || pl) el.style.padding = pt+'px '+pr+'px '+pb+'px '+pl+'px';
  const r = n.cornerRadiusDp ?? (n.backgroundColor ? 20 : 0);
  if (n.backgroundColor) {
    const c = toCSS(n.backgroundColor);
    if (c) el.style.backgroundColor = c;
    el.style.borderRadius = r + 'px';
    el.style.overflow = 'hidden';
  } else if (n.cornerRadiusDp != null) {
    el.style.borderRadius = n.cornerRadiusDp + 'px';
  }
  if (n.alpha != null) el.style.opacity = String(Math.max(0, Math.min(1, n.alpha)));
  if (n.weight != null) {
    el.style.flex = n.weight + ' 1 0px';
    if (n.minWidthDp == null) el.style.minWidth = '0';
  }
}

function mkNode(n, dark) {
  const base = dark ? '#FFFFFF' : '#333333';

  if (n.type === 'image') {
    const w = document.createElement('div');
    applyBase(w, n);
    w.style.overflow = 'hidden';
    if (n.aspectRatio) w.style.aspectRatio = String(n.aspectRatio);
    if (n.actionUrl) w.classList.add('lcg-act');
    const img = document.createElement('img');
    img.src = n.imageUrl || '';
    img.alt = n.contentDescription || '';
    img.style.cssText = 'display:block;width:100%;height:100%';
    img.style.objectFit = SC[n.contentScale] || 'cover';
    w.appendChild(img);
    return w;
  }

  const el = document.createElement('div');
  applyBase(el, n);
  if (n.actionUrl) el.classList.add('lcg-act');

  switch (n.type) {
    case 'box': {
      el.style.display = 'grid';
      el.style.gridTemplateAreas = '"s"';
      el.style.placeItems = CA[n.contentAlignment] || 'start start';
      (n.children || []).forEach(c => {
        const ce = mkNode(c, dark);
        ce.style.gridArea = 's';
        if (c.fillMaxHeight) ce.style.alignSelf = 'stretch';
        if (c.fillMaxWidth) { ce.style.justifySelf = 'stretch'; ce.style.width = '100%'; }
        el.appendChild(ce);
      });
      break;
    }
    case 'column': {
      el.style.cssText += ';display:flex;flex-direction:column;min-width:0';
      if (n.spacingDp) el.style.gap = n.spacingDp + 'px';
      el.style.justifyContent = ARR[n.verticalArrangement] || 'flex-start';
      el.style.alignItems = ARR[n.horizontalAlignment] || 'flex-start';
      (n.children || []).forEach(c => el.appendChild(mkNode(c, dark)));
      break;
    }
    case 'row': {
      el.style.cssText += ';display:flex;flex-direction:row;min-width:0;flex-wrap:nowrap';
      if (n.spacingDp) el.style.gap = n.spacingDp + 'px';
      el.style.justifyContent = ARR[n.horizontalArrangement] || 'flex-start';
      el.style.alignItems = ARR[n.verticalAlignment] || 'flex-start';
      (n.children || []).forEach(c => el.appendChild(mkNode(c, dark)));
      el.dataset.row = JSON.stringify({
        cb: n.collapseBelowDp,
        sp: n.spacingDp || 0,
        mw: (n.children || []).map(c => c.minWidthDp || 0),
      });
      break;
    }
    case 'text': {
      el.style.minWidth = '0';
      el.style.wordBreak = 'break-word';
      el.style.whiteSpace = 'pre-wrap';
      const t = TYP[n.style] || TYP.bodyMedium;
      el.style.fontSize = t.fs; el.style.fontWeight = t.fw;
      el.style.letterSpacing = t.ls; el.style.lineHeight = t.lh;
      if (n.fontSizeSp) el.style.fontSize = n.fontSizeSp + 'px';
      if (n.fontWeight) el.style.fontWeight = FW[n.fontWeight] || n.fontWeight;
      if (n.fontStyle === 'italic') el.style.fontStyle = 'italic';
      if (n.textAlign) {
        const ta = n.textAlign === 'centre' ? 'center'
          : (n.textAlign === 'right' || n.textAlign === 'end') ? 'right' : n.textAlign;
        el.style.textAlign = ta;
      }
      const c = n.color ? toCSS(n.color) : base;
      if (c) el.style.color = c;
      el.textContent = n.text || '';
      break;
    }
    case 'spacer': {
      el.style.display = 'block'; el.style.flexShrink = '0';
      if (n.widthDp != null && n.heightDp != null) { /* already applied */ }
      else if (n.spacingDp != null) el.style.height = n.spacingDp + 'px';
      else { el.style.width = '8px'; el.style.height = '8px'; }
      break;
    }
    case 'divider': {
      el.style.cssText += ';width:100%;height:1px;border:none';
      const dc = n.color ? toCSS(n.color) : (dark ? '#49454F' : '#CAC4D0');
      if (dc) el.style.backgroundColor = dc;
      break;
    }
    case 'markdown': {
      el.style.minWidth = '0'; el.style.wordBreak = 'break-word';
      el.classList.add('lcg-md');
      el.style.color = base;
      if (typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined') {
        el.innerHTML = DOMPurify.sanitize(marked.parse(n.text || ''));
      } else {
        const p = document.createElement('pre');
        p.style.whiteSpace = 'pre-wrap'; p.textContent = n.text || '';
        el.appendChild(p);
      }
      break;
    }
    default: break;
  }
  return el;
}

function collapseRows(container) {
  container.querySelectorAll('[data-row]').forEach(rowEl => {
    try {
      const d = JSON.parse(rowEl.dataset.row);
      const rw = rowEl.clientWidth;
      let collapse = false;
      if (d.cb && rw <= d.cb) { collapse = true; }
      else if (d.mw.some(v => v > 0)) {
        const req = d.mw.reduce((a,b) => a+b, 0) + (d.mw.length - 1) * d.sp;
        if (rw < req) collapse = true;
      }
      const wasCollapsed = rowEl.dataset.collapsed === '1';
      if (collapse && !wasCollapsed) {
        rowEl.style.flexDirection = 'column';
        rowEl.querySelectorAll(':scope > *').forEach(c => {
          if (c.style.flex || c.style.width) {
            c.dataset.savedFlex = c.style.flex || '';
            c.dataset.savedWidth = c.style.width || '';
          }
          c.style.flex = '';
          c.style.width = '100%';
        });
        rowEl.dataset.collapsed = '1';
      } else if (!collapse && wasCollapsed) {
        rowEl.style.flexDirection = 'row';
        rowEl.querySelectorAll(':scope > *').forEach(c => {
          if (c.dataset.savedFlex !== undefined) {
            c.style.flex = c.dataset.savedFlex;
            c.style.width = c.dataset.savedWidth;
            delete c.dataset.savedFlex;
            delete c.dataset.savedWidth;
          } else {
            c.style.width = '';
          }
        });
        delete rowEl.dataset.collapsed;
      }
    } catch (e) {}
  });
}

/* ── TREE ────────────────────────────────────────────────── */
const CONTAINERS = new Set(['box', 'column', 'row']);
const ALL_TYPES  = ['box', 'column', 'row', 'text', 'image', 'markdown', 'spacer', 'divider'];

function renderTree() {
  const el = document.getElementById('lcg-tree');
  const rootBtn = document.getElementById('lcg-add-root-btn');
  if (!S.spec) {
    el.innerHTML = '<div class="lcg-tree-empty">No spec loaded — add a root node to start.</div>';
    rootBtn.style.display = '';
    return;
  }
  rootBtn.style.display = 'none';
  el.innerHTML = '';
  walkTree(S.spec, [], el);
  const sel = el.querySelector('.lcg-sel');
  if (sel) sel.scrollIntoView({ block: 'nearest' });
}

function walkTree(n, path, container) {
  const depth = path.length;
  const key = pk(path);
  const isCollapsed = S.collapsed.has(key);
  const hasKids = !!(n.children && n.children.length);
  const isSel = S.sel !== null && pk(S.sel) === key;

  const row = document.createElement('div');
  row.className = 'lcg-tree-node' + (isSel ? ' lcg-sel' : '');
  row.dataset.path = key;
  if (depth > 0) { row.draggable = true; row.dataset.draggable = '1'; }

  const ind = document.createElement('span');
  ind.className = 'lcg-n-indent';
  ind.style.paddingLeft = (depth * 16 + 6) + 'px';
  row.appendChild(ind);

  const tog = document.createElement('span');
  tog.className = 'lcg-n-tog';
  tog.dataset.tpath = key;
  tog.textContent = hasKids ? (isCollapsed ? '▶' : '▼') : '·';
  row.appendChild(tog);

  const type = document.createElement('span');
  type.className = 'lcg-n-type';
  type.textContent = n.type;
  row.appendChild(type);

  const prev = document.createElement('span');
  prev.className = 'lcg-n-prev';
  if (n.type === 'text' || n.type === 'markdown') prev.textContent = (n.text || '').slice(0, 22);
  else if (n.type === 'image') prev.textContent = n.imageUrl ? '↗ image' : '';
  row.appendChild(prev);

  const acts = document.createElement('span');
  acts.className = 'lcg-n-acts';

  if (CONTAINERS.has(n.type)) {
    const ab = btn('+', 'Add child'); ab.dataset.addp = key; acts.appendChild(ab);
  }
  if (depth > 0) {
    const ub = btn('↑', 'Move up');   ub.dataset.mvup = key;  acts.appendChild(ub);
    const db = btn('↓', 'Move down'); db.dataset.mvdn = key;  acts.appendChild(db);
  }
  const xb = btn('✕', depth === 0 ? 'Clear all' : 'Delete');
  xb.classList.add('lcg-n-del'); xb.dataset.del = key;
  acts.appendChild(xb);

  row.appendChild(acts);
  container.appendChild(row);

  if (hasKids && !isCollapsed) {
    n.children.forEach((c, i) => walkTree(c, [...path, i], container));
  }
}

function btn(txt, title) {
  const b = document.createElement('button');
  b.className = 'lcg-n-btn'; b.title = title; b.textContent = txt;
  return b;
}

/* ── PROPERTIES ─────────────────────────────────────────── */
const STYLES_OPTS = ['','displayLarge','displayMedium','displaySmall',
  'headlineLarge','headlineMedium','headlineSmall',
  'titleLarge','titleMedium','titleSmall',
  'bodyLarge','bodyMedium','bodySmall',
  'labelLarge','labelMedium','labelSmall'];

function renderProps() {
  const el = document.getElementById('lcg-props');
  const title = document.getElementById('lcg-props-title');
  if (S.sel === null || !S.spec) {
    title.textContent = 'Properties';
    el.innerHTML = '<div class="lcg-props-empty">Select a node to edit its properties.</div>';
    return;
  }
  const n = gn(S.spec, S.sel);
  if (!n) { el.innerHTML = '<div class="lcg-props-empty">Node not found.</div>'; return; }
  title.textContent = 'Properties';
  el.innerHTML = '';
  const form = document.createElement('div');
  form.className = 'lcg-props-form';

  // Type selector
  const tr = document.createElement('div'); tr.className = 'lcg-type-row';
  tr.innerHTML = '<label>Type</label>';
  const ts = document.createElement('select'); ts.dataset.field = 'type';
  ALL_TYPES.forEach(t => {
    const o = document.createElement('option');
    o.value = t; o.textContent = t;
    if (t === n.type) o.selected = true;
    ts.appendChild(o);
  });
  tr.appendChild(ts); form.appendChild(tr);

  // Content fields
  const cf = contentFields(n);
  if (cf.length) form.appendChild(mkSec('Content', cf, n, 'content'));

  // Layout fields
  const lf = layoutFields(n);
  if (lf.length) form.appendChild(mkSec('Layout', lf, n, 'layout'));

  // Padding
  form.appendChild(mkSec('Padding', [
    {f:'paddingDp',         l:'All (dp)',        t:'number'},
    {f:'paddingHorizontalDp',l:'Horizontal (dp)', t:'number'},
    {f:'paddingVerticalDp', l:'Vertical (dp)',   t:'number'},
    {f:'paddingStartDp',    l:'Start (dp)',      t:'number'},
    {f:'paddingTopDp',      l:'Top (dp)',        t:'number'},
    {f:'paddingEndDp',      l:'End (dp)',        t:'number'},
    {f:'paddingBottomDp',   l:'Bottom (dp)',     t:'number'},
  ], n, 'padding'));

  // Appearance
  form.appendChild(mkSec('Appearance', [
    {f:'backgroundColor', l:'Background colour', t:'color'},
    {f:'cornerRadiusDp',  l:'Corner radius (dp)', t:'number'},
    {f:'alpha',           l:'Alpha (0–1)',  t:'number', step:'0.01', min:'0', max:'1'},
    {f:'actionUrl',       l:'Action URL',  t:'url'},
  ], n, 'appearance'));

  el.appendChild(form);
}

function contentFields(n) {
  switch (n.type) {
    case 'text': return [
      {f:'text',      l:'Text',        t:'textarea'},
      {f:'style',     l:'Style',       t:'select', opts: STYLES_OPTS},
      {f:'fontSizeSp',l:'Font size (sp)', t:'number'},
      {f:'fontWeight',l:'Font weight', t:'select', opts:['','light','medium','semi_bold','bold']},
      {f:'fontStyle', l:'Font style',  t:'select', opts:['','italic']},
      {f:'textAlign', l:'Text align',  t:'select', opts:['','start','center','end','justify']},
      {f:'color',     l:'Colour',      t:'color'},
    ];
    case 'markdown': return [{f:'text', l:'Markdown', t:'textarea'}];
    case 'image': return [
      {f:'imageUrl',          l:'Image URL',         t:'text'},
      {f:'contentDescription',l:'Content description',t:'text'},
      {f:'aspectRatio',       l:'Aspect ratio',       t:'number', step:'0.01'},
      {f:'contentScale',      l:'Content scale', t:'select',
        opts:['','crop','fit','fill_bounds','fill_width','fill_height','inside','none']},
    ];
    case 'divider': return [{f:'color', l:'Colour', t:'color'}];
    default: return [];
  }
}

function layoutFields(n) {
  const base = [
    {f:'fillMaxWidth', l:'Fill max width',   t:'checkbox'},
    {f:'fillMaxHeight',l:'Fill max height',  t:'checkbox'},
    {f:'widthDp',      l:'Width (dp)',        t:'number'},
    {f:'heightDp',     l:'Height (dp)',       t:'number'},
    {f:'minWidthDp',   l:'Min width (dp)',    t:'number'},
    {f:'maxWidthDp',   l:'Max width (dp)',    t:'number'},
    {f:'minHeightDp',  l:'Min height (dp)',   t:'number'},
    {f:'weight',       l:'Weight',            t:'number', step:'0.1'},
  ];
  if (n.type === 'spacer') return [
    {f:'widthDp',  l:'Width (dp)',   t:'number'},
    {f:'heightDp', l:'Height (dp)',  t:'number'},
    {f:'spacingDp',l:'Spacing (dp)', t:'number'},
  ];
  const extras = {
    box:    [{f:'contentAlignment', l:'Content alignment', t:'select',
               opts:['','top_start','top_center','top_end','center_start','center','center_end','bottom_start','bottom_center','bottom_end']}],
    column: [
      {f:'spacingDp',           l:'Spacing (dp)',          t:'number'},
      {f:'verticalArrangement', l:'Vertical arrangement',  t:'select',
        opts:['','top','center','bottom','space_between','space_around','space_evenly']},
      {f:'horizontalAlignment', l:'Horizontal alignment',  t:'select',
        opts:['','start','center','end']},
    ],
    row: [
      {f:'spacingDp',             l:'Spacing (dp)',           t:'number'},
      {f:'horizontalArrangement', l:'Horizontal arrangement', t:'select',
        opts:['','start','center','end','space_between','space_around','space_evenly']},
      {f:'verticalAlignment',     l:'Vertical alignment',     t:'select',
        opts:['','top','center','bottom']},
      {f:'collapseBelowDp',       l:'Collapse below (dp)',    t:'number'},
    ],
  };
  return [...base, ...(extras[n.type] || [])];
}

function mkSec(title, fields, n, key) {
  const sec = document.createElement('div'); sec.className = 'lcg-sec';
  const isOpen = S.secState[key] !== false;

  const hd = document.createElement('div'); hd.className = 'lcg-sec-hd'; hd.dataset.sec = key;
  hd.innerHTML = '<span>' + title + '</span><span class="lcg-sec-tog">' + (isOpen ? '▼' : '▶') + '</span>';
  sec.appendChild(hd);

  const body = document.createElement('div'); body.className = 'lcg-sec-body';
  if (!isOpen) body.style.display = 'none';

  fields.forEach(fd => {
    const div = document.createElement('div'); div.className = 'lcg-f';

    if (fd.t === 'checkbox') {
      const lbl = document.createElement('label'); lbl.className = 'lcg-cb-label';
      const cb = document.createElement('input'); cb.type = 'checkbox';
      cb.checked = !!n[fd.f]; cb.dataset.field = fd.f;
      lbl.appendChild(cb);
      lbl.appendChild(document.createTextNode(' ' + fd.l));
      div.appendChild(lbl);
    } else if (fd.t === 'color') {
      const lbl = document.createElement('label'); lbl.textContent = fd.l;
      div.appendChild(lbl);
      const row = document.createElement('div'); row.className = 'lcg-color-row';
      const sw = document.createElement('span'); sw.className = 'lcg-swatch';
      sw.style.backgroundColor = toCSS(n[fd.f]) || 'transparent';
      row.appendChild(sw);
      const inp = document.createElement('input'); inp.type = 'text';
      inp.value = n[fd.f] || ''; inp.placeholder = '#AARRGGBB or #RRGGBB';
      inp.dataset.field = fd.f; inp.dataset.swatch = '1';
      row.appendChild(inp); div.appendChild(row);
    } else if (fd.t === 'select') {
      const lbl = document.createElement('label'); lbl.textContent = fd.l;
      div.appendChild(lbl);
      const sel = document.createElement('select'); sel.dataset.field = fd.f;
      (fd.opts || []).forEach(o => {
        const op = document.createElement('option');
        op.value = o; op.textContent = o || '— none —';
        if (o === (n[fd.f] || '')) op.selected = true;
        sel.appendChild(op);
      });
      div.appendChild(sel);
    } else if (fd.t === 'textarea') {
      const lbl = document.createElement('label'); lbl.textContent = fd.l;
      div.appendChild(lbl);
      const ta = document.createElement('textarea'); ta.value = n[fd.f] || '';
      ta.dataset.field = fd.f; div.appendChild(ta);
    } else {
      const lbl = document.createElement('label'); lbl.textContent = fd.l;
      div.appendChild(lbl);
      const inp = document.createElement('input'); inp.type = fd.t || 'text';
      inp.value = n[fd.f] != null ? n[fd.f] : '';
      inp.dataset.field = fd.f;
      if (fd.step != null) inp.step = fd.step;
      if (fd.min  != null) inp.min  = fd.min;
      if (fd.max  != null) inp.max  = fd.max;
      div.appendChild(inp);
    }
    body.appendChild(div);
  });

  sec.appendChild(body);
  return sec;
}

/* ── PREVIEW ─────────────────────────────────────────────── */
let roObs = null;

function renderPreview() {
  const card = document.getElementById('lcg-card');
  if (roObs) { roObs.disconnect(); roObs = null; }
  card.className = 'lcg-card-wrap' + (S.dark ? ' lcg-dark' : '');
  card.innerHTML = '';

  if (!S.spec) {
    card.innerHTML = '<div class="lcg-prev-empty">No spec loaded.</div>';
    return;
  }
  try {
    card.appendChild(mkNode(S.spec, S.dark));
    collapseRows(card);
    roObs = new ResizeObserver(() => collapseRows(card));
    roObs.observe(card);
  } catch (e) {
    card.innerHTML = '';
    const errDiv = document.createElement('div');
    errDiv.style.cssText = 'color:#c30000;font-family:Roboto,sans-serif;font-size:13px';
    errDiv.textContent = 'Render error: ' + e.message;
    card.appendChild(errDiv);
  }
}

/* ── JSON ────────────────────────────────────────────────── */
function updateJSON() {
  const out  = document.getElementById('lcg-json-out');
  const ctr  = document.getElementById('lcg-counter');
  const warn = document.getElementById('lcg-cnt-warn');
  const copyBtn = document.getElementById('lcg-copy-btn');
  const dlBtn   = document.getElementById('lcg-dl-btn');
  if (!S.spec) {
    out.value = ''; ctr.textContent = '0 chars';
    ctr.className = 'lcg-cnt-green'; warn.textContent = '';
    if (copyBtn) { copyBtn.disabled = true; copyBtn.title = 'Nothing to copy'; }
    if (dlBtn)   { dlBtn.disabled = true;   dlBtn.title   = 'Nothing to download'; }
    return;
  }
  const json = JSON.stringify(S.spec);
  out.value = json;
  const len = json.length;
  const fmt = len.toLocaleString();
  let tooBig = false;
  if (len <= 9999) {
    ctr.textContent = fmt + ' chars'; ctr.className = 'lcg-cnt-green'; warn.textContent = '';
  } else if (len <= 20000) {
    ctr.textContent = fmt + ' chars'; ctr.className = 'lcg-cnt-amber';
    warn.textContent = 'Large spec — may approach delivery limits depending on your EMM.';
  } else {
    ctr.textContent = fmt + ' chars — exceeds recommended limit';
    ctr.className = 'lcg-cnt-red';
    warn.textContent = 'Specs over 20,000 chars may not deliver reliably. Copy and download are disabled — trim the spec to continue.';
    tooBig = true;
  }
  if (copyBtn) {
    copyBtn.disabled = tooBig;
    copyBtn.title = tooBig ? 'Spec exceeds 20,000 chars — trim before copying' : '';
  }
  if (dlBtn) {
    dlBtn.disabled = tooBig;
    dlBtn.title = tooBig ? 'Spec exceeds 20,000 chars — trim before downloading' : '';
  }
}

function renderAll() { renderTree(); renderProps(); renderPreview(); updateJSON(); }

/* ── IMPORT ─────────────────────────────────────────────── */
function validateNode(n, path) {
  const where = path.length ? ' at children[' + path.join('][') + ']' : '';
  if (!n || typeof n !== 'object' || Array.isArray(n)) {
    return (path.length ? 'Node' : 'Root') + where + ' must be a JSON object.';
  }
  if (!n.type || typeof n.type !== 'string') {
    return (path.length ? 'Node' : 'Root') + where + ' must have a "type" field.';
  }
  if (!ALL_TYPES.includes(n.type)) {
    return 'Unknown type "' + n.type + '"' + where + '. Must be one of: ' + ALL_TYPES.join(', ') + '.';
  }
  if (n.children !== undefined) {
    if (!Array.isArray(n.children)) {
      return 'Node' + where + ' has non-array "children".';
    }
    if (!CONTAINERS.has(n.type)) {
      return 'Node' + where + ' (type "' + n.type + '") cannot have children.';
    }
    for (let i = 0; i < n.children.length; i++) {
      const e = validateNode(n.children[i], path.concat(i));
      if (e) return e;
    }
  }
  return null;
}

function parseImport(str) {
  let p;
  try { p = JSON.parse(str.trim()); } catch (e) { return { err: 'Invalid JSON: ' + e.message }; }
  const err = validateNode(p, []);
  if (err) return { err };
  return { spec: p };
}

function closeImportModal() {
  document.getElementById('lcg-import-modal').classList.add('lcg-modal-off');
  document.getElementById('lcg-import-ta').value = '';
  const e = document.getElementById('lcg-import-err');
  e.className = 'lcg-err-off'; e.textContent = '';
}

/* ── TYPE MENU ───────────────────────────────────────────── */
let menuPath = null;

function showMenu(anchor, forPath) {
  menuPath = forPath;
  const m = document.getElementById('lcg-type-menu');
  const r = anchor.getBoundingClientRect();
  m.style.top  = (r.bottom + window.scrollY + 4) + 'px';
  m.style.left = (r.left   + window.scrollX)     + 'px';
  m.innerHTML  = '';
  ALL_TYPES.forEach(t => {
    const d = document.createElement('div'); d.className = 'lcg-t-opt';
    d.textContent = t; d.dataset.mtype = t; m.appendChild(d);
  });
  m.classList.remove('lcg-menu-off');
  setTimeout(() => document.addEventListener('click', closeMenu, { once: true }), 0);
}

function closeMenu() { document.getElementById('lcg-type-menu').classList.add('lcg-menu-off'); menuPath = null; }

/* ── DRAG-DROP ───────────────────────────────────────────── */
let dragP = null;

function isAncestorPath(anc, desc) {
  if (anc.length >= desc.length) return false;
  for (let i = 0; i < anc.length; i++) if (anc[i] !== desc[i]) return false;
  return true;
}

function adjustPathAfterDelete(target, deleted) {
  if (deleted.length === 0) return target;
  const d = deleted.length - 1;
  if (target.length <= d) return target;
  for (let i = 0; i < d; i++) if (target[i] !== deleted[i]) return target;
  if (deleted[d] < target[d]) {
    const adj = target.slice();
    adj[d] = adj[d] - 1;
    return adj;
  }
  return target;
}

function setupDragDrop() {
  const tree = document.getElementById('lcg-tree');
  tree.addEventListener('dragstart', e => {
    const row = e.target.closest('.lcg-tree-node[data-draggable]');
    if (!row) return;
    dragP = JSON.parse(row.dataset.path);
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', row.dataset.path);
    setTimeout(() => { if (row.isConnected) row.style.opacity = '.4'; }, 0);
  });
  tree.addEventListener('dragend', e => {
    const row = e.target.closest('.lcg-tree-node');
    if (row) row.style.opacity = '';
    tree.querySelectorAll('.lcg-drag-over').forEach(r => r.classList.remove('lcg-drag-over'));
    dragP = null;
  });
  tree.addEventListener('dragover', e => {
    e.preventDefault(); e.dataTransfer.dropEffect = 'move';
    tree.querySelectorAll('.lcg-drag-over').forEach(r => r.classList.remove('lcg-drag-over'));
    const row = e.target.closest('.lcg-tree-node');
    if (row && dragP) row.classList.add('lcg-drag-over');
  });
  tree.addEventListener('dragleave', e => {
    const row = e.target.closest('.lcg-tree-node');
    if (row) row.classList.remove('lcg-drag-over');
  });
  tree.addEventListener('drop', e => {
    e.preventDefault();
    const row = e.target.closest('.lcg-tree-node');
    if (!row || !dragP) return;
    const tPath = JSON.parse(row.dataset.path);
    if (pk(dragP) === pk(tPath)) return;
    // prevent dropping onto own descendant
    if (isAncestorPath(dragP, tPath)) return;

    const tNode = gn(S.spec, tPath);
    if (!tNode) return;
    const dragNode = JSON.parse(JSON.stringify(gn(S.spec, dragP)));
    if (!dragNode) return;

    if (CONTAINERS.has(tNode.type)) {
      // Move into target container as last child.
      delNode(S.spec, dragP);
      const adjTarget = adjustPathAfterDelete(tPath, dragP);
      const par = gn(S.spec, adjTarget);
      if (par && CONTAINERS.has(par.type)) {
        if (!par.children) par.children = [];
        par.children.push(dragNode);
        S.sel = [...adjTarget, par.children.length - 1];
      }
    } else {
      // Reorder within same parent (target is a leaf — drop before it).
      const dp = dragP.slice(0, -1), tp = tPath.slice(0, -1);
      if (pk(dp) === pk(tp)) {
        const par = gn(S.spec, dp);
        if (par && par.children) {
          const fi = dragP[dragP.length - 1];
          const tiOrig = tPath[tPath.length - 1];
          const item = par.children.splice(fi, 1)[0];
          const ti = tiOrig > fi ? tiOrig - 1 : tiOrig;
          par.children.splice(ti, 0, item);
          S.sel = [...dp, ti];
        }
      }
    }
    renderAll();
  });
}

/* ── INIT ────────────────────────────────────────────────── */
function setWidth(w) {
  S.pw = Math.max(280, Math.min(700, parseInt(w) || 360));
  document.getElementById('lcg-phone').style.width = S.pw + 'px';
  document.getElementById('lcg-w-range').value = S.pw;
  document.getElementById('lcg-w-num').value   = S.pw;
  renderPreview();
}

function init() {
  setWidth(360);
  renderAll();

  // Sample
  document.getElementById('lcg-sample-link').addEventListener('click', () => {
    const r = parseImport(JSON.stringify(SAMPLE));
    if (r.err) { alert(r.err); return; }
    S.spec = r.spec; S.sel = null; S.collapsed.clear();
    renderAll();
  });

  // Import modal
  document.getElementById('lcg-import-btn').addEventListener('click', () => {
    document.getElementById('lcg-import-modal').classList.remove('lcg-modal-off');
    document.getElementById('lcg-import-ta').focus();
  });
  document.getElementById('lcg-import-close').addEventListener('click',  closeImportModal);
  document.getElementById('lcg-import-cancel').addEventListener('click', closeImportModal);
  document.getElementById('lcg-import-modal').addEventListener('click', e => {
    if (e.target === document.getElementById('lcg-import-modal')) closeImportModal();
  });
  document.getElementById('lcg-import-ok').addEventListener('click', () => {
    const str = document.getElementById('lcg-import-ta').value;
    const r   = parseImport(str);
    const err = document.getElementById('lcg-import-err');
    if (r.err) {
      err.textContent = r.err; err.className = 'lcg-err';
    } else {
      S.spec = r.spec; S.sel = null; S.collapsed.clear();
      renderAll(); closeImportModal();
    }
  });

  // Dark toggle
  document.getElementById('lcg-dark-toggle').addEventListener('change', e => {
    S.dark = e.target.checked; renderPreview();
  });

  // Width
  document.getElementById('lcg-w-range').addEventListener('input',  e => setWidth(e.target.value));
  document.getElementById('lcg-w-num').addEventListener('change',   e => setWidth(e.target.value));

  // Add root
  document.getElementById('lcg-add-root-btn').addEventListener('click', e => showMenu(e.target, []));

  // Type menu
  document.getElementById('lcg-type-menu').addEventListener('click', e => {
    const item = e.target.closest('[data-mtype]');
    if (!item || menuPath === null) return;
    const type = item.dataset.mtype;
    const p = menuPath;
    if (p.length === 0 && !S.spec) {
      S.spec = { type }; S.sel = [];
    } else {
      const np = addChild(S.spec, p, type);
      if (np) S.sel = np;
    }
    renderAll(); closeMenu();
  });

  // Tree: clicks (delegated)
  document.getElementById('lcg-tree').addEventListener('click', e => {
    const row = e.target.closest('.lcg-tree-node');
    if (!row) return;
    const path = JSON.parse(row.dataset.path);

    // Toggle collapse
    if (e.target.dataset.tpath !== undefined) {
      const k = e.target.dataset.tpath;
      S.collapsed.has(k) ? S.collapsed.delete(k) : S.collapsed.add(k);
      renderTree(); return;
    }
    // Add child
    if (e.target.dataset.addp !== undefined) {
      e.stopPropagation();
      showMenu(e.target, JSON.parse(e.target.dataset.addp)); return;
    }
    // Move up
    if (e.target.dataset.mvup !== undefined) {
      e.stopPropagation();
      const np = moveNode(S.spec, JSON.parse(e.target.dataset.mvup), -1);
      if (np) S.sel = np; renderAll(); return;
    }
    // Move down
    if (e.target.dataset.mvdn !== undefined) {
      e.stopPropagation();
      const np = moveNode(S.spec, JSON.parse(e.target.dataset.mvdn), 1);
      if (np) S.sel = np; renderAll(); return;
    }
    // Delete
    if (e.target.dataset.del !== undefined) {
      e.stopPropagation();
      const dp = JSON.parse(e.target.dataset.del);
      if (dp.length === 0) {
        if (!confirm('Clear the entire spec?')) return;
        S.spec = null; S.sel = null;
      } else {
        const dk = pk(dp), sk = S.sel ? pk(S.sel) : null;
        if (sk && (sk === dk || sk.startsWith(dk.slice(0,-1) + ','))) {
          S.sel = dp.length > 1 ? dp.slice(0,-1) : [];
        }
        delNode(S.spec, dp);
        if (S.sel && pk(S.sel) === dk) S.sel = dp.length > 1 ? dp.slice(0,-1) : [];
      }
      renderAll(); return;
    }
    // Select
    S.sel = path; renderTree(); renderProps();
  });

  setupDragDrop();

  // Props: change/input (delegated)
  const propsEl = document.getElementById('lcg-props');
  function onPropChange(e) {
    const el = e.target;
    if (!el.dataset.field || S.sel === null || !S.spec) return;
    const n = gn(S.spec, S.sel);
    if (!n) return;
    const f = el.dataset.field;

    // Type change
    if (f === 'type') {
      const v = el.value;
      if (v === n.type) return;
      const was = CONTAINERS.has(n.type), is = CONTAINERS.has(v);
      if (was && !is && n.children && n.children.length) {
        if (!confirm('Changing to "' + v + '" will remove ' + n.children.length + ' child node(s). Continue?')) {
          el.value = n.type; return;
        }
      }
      n.type = v;
      if (!is) delete n.children;
      renderAll(); return;
    }

    let v;
    if (el.type === 'checkbox') {
      v = el.checked;
    } else if (el.type === 'number') {
      v = el.value === '' ? undefined : parseFloat(el.value);
    } else {
      v = el.value === '' ? undefined : el.value;
    }
    if (v === undefined) delete n[f]; else n[f] = v;

    if (el.dataset.swatch) {
      const sw = el.closest('.lcg-color-row').querySelector('.lcg-swatch');
      if (sw) sw.style.backgroundColor = toCSS(v || '') || 'transparent';
    }
    renderPreview(); updateJSON();
  }
  propsEl.addEventListener('change', onPropChange);
  propsEl.addEventListener('input', e => {
    if (e.target.tagName === 'TEXTAREA' || (e.target.tagName === 'INPUT' && e.target.type === 'text'))
      onPropChange(e);
  });

  // Section toggle (delegated)
  propsEl.addEventListener('click', e => {
    const hd = e.target.closest('[data-sec]');
    if (!hd) return;
    const k = hd.dataset.sec;
    const body = hd.nextElementSibling;
    if (!body) return;
    const open = body.style.display !== 'none';
    body.style.display = open ? 'none' : '';
    S.secState[k] = !open;
    hd.querySelector('.lcg-sec-tog').textContent = open ? '▶' : '▼';
  });

  // JSON buttons
  document.getElementById('lcg-copy-btn').addEventListener('click', () => {
    const v = document.getElementById('lcg-json-out').value;
    if (!v || v.length > 20000) return;
    navigator.clipboard.writeText(v).then(() => {
      const b = document.getElementById('lcg-copy-btn');
      const o = b.textContent; b.textContent = 'Copied!';
      setTimeout(() => { b.textContent = o; }, 1600);
    });
  });
  document.getElementById('lcg-dl-btn').addEventListener('click', () => {
    const v = document.getElementById('lcg-json-out').value;
    if (!v || v.length > 20000) return;
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([v], { type: 'application/json' }));
    a.download = 'layout-card-spec.json';
    a.click(); URL.revokeObjectURL(a.href);
  });

  // Keyboard: Escape closes modals/menus
  document.addEventListener('keydown', e => {
    if (e.key !== 'Escape') return;
    if (!document.getElementById('lcg-import-modal').classList.contains('lcg-modal-off')) closeImportModal();
    if (!document.getElementById('lcg-type-menu').classList.contains('lcg-menu-off')) closeMenu();
  });
}

if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
else init();

})();
</script>
