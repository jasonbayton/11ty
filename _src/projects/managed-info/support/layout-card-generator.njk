  font-size: 13px; padding: 6px 16px; cursor: pointer;
  border: 1px solid var(--orange); border-radius: 4px;
  background: var(--orange); color: #fff; font-family: inherit;
  box-shadow: none; font-weight: 600;
}
.lcg-primary-btn:hover { opacity: .9; }
.lcg-secondary-btn {
  font-size: 13px; padding: 6px 14px; cursor: pointer;
  border: 1px solid var(--orange); border-radius: 4px;
  background: transparent; color: var(--orange); font-family: inherit;
  box-shadow: none;
}
.lcg-secondary-btn:hover { background: rgba(255,69,0,.08); }
#lcg-import-btn {
  font-size: 12px; padding: 4px 12px; cursor: pointer;
