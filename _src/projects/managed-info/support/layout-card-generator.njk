  background: var(--background); border-radius: 12px; padding: 20px 24px;
  width: min(540px, calc(100vw - 32px));
  box-shadow: 0 8px 32px rgba(0,0,0,.25);
}
.lcg-modal-hd {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;
}
.lcg-modal-hd strong { font-size: 15px; }
#lcg-import-close {
  background: none; border: none; font-size: 20px; cursor: pointer;
  padding: 0 4px; color: var(--text); line-height: 1; box-shadow: none;
}
.lcg-modal-hint { font-size: 13px; margin: 0 0 8px; opacity: .7; }
#lcg-import-ta {
  width: 100%; box-sizing: border-box;
  font-family: 'SF Mono', 'Consolas', monospace; font-size: 12px;
  padding: 8px; border: 1px solid var(--light); border-radius: 6px;
  background: var(--subtle-bg); color: var(--text);
  resize: vertical; min-height: 130px;
}
.lcg-err {
  font-size: 12px; color: #c30000; margin-top: 6px;
  padding: 5px 8px; background: rgba(195,0,0,.07);
  border-radius: 4px; border-left: 3px solid #c30000;
}
.lcg-err-off { display: none; }
.lcg-modal-ft {
  display: flex; gap: 8px; justify-content: flex-end; margin-top: 12px;
}
.lcg-modal-ft button { font-size: 13px; border-radius: 5px; cursor: pointer; font-family: inherit; }
#lcg-import-cancel {
  background: none; border: 1px solid var(--light); color: var(--text);
  box-shadow: none; padding: 6px 16px;
}
#lcg-import-cancel:hover { background: var(--subtle-bg); }

/* Type dropdown menu */
#lcg-type-menu {
  position: fixed; background: var(--background);
  border: 1px solid var(--light); border-radius: 8px;
  box-shadow: 0 4px 20px rgba(0,0,0,.15); z-index: 9999;
  min-width: 120px; padding: 4px 0; overflow: hidden;
}
#lcg-type-menu.lcg-menu-off { display: none; }
.lcg-t-opt {
  padding: 6px 14px; cursor: pointer; font-size: 13px; color: var(--text);
}
.lcg-t-opt:hover { background: rgba(255,69,0,.08); color: var(--orange); }

/* Dark input overrides */
[data-theme="dark"] .lcg-f input,
[data-theme="dark"] .lcg-f textarea,
[data-theme="dark"] .lcg-f select,
[data-theme="dark"] .lcg-type-row select,
[data-theme="dark"] #lcg-import-ta,
[data-theme="dark"] #lcg-json-out {
  background: var(--input); border-color: #3f3f3f;
}

/* Responsive */
@media (max-width: 900px) {
  #lcg-main { grid-template-columns: 1fr; }
  #lcg-tree { max-height: 220px; }
  #lcg-props { max-height: 300px; }
}
