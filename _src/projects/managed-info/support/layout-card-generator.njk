// When a clipped container (one with backgroundColor / overflow:hidden)
// stacks children flush against each other, the children's own
// border-radius is redundant: the parent's clip already shapes the
// outer boundary, and any radius on a sibling-facing edge creates a
// visible "cut" exposing the parent's background. Strip all corners on
// these children and let the parent's clip do the work, which avoids
// both the unwanted cuts and the subpixel double-clip artifact that
// reads as a 1-2px inset on the image inside an image card.
//
// Skip the trim when the container uses spacingDp, because the gap
// between children gives each child a clean parent-bg strip and the
// rounded corners read as intentional.
function trimChildCorners(el, n, axis) {
  if (!n.backgroundColor) return;
  if (n.spacingDp && n.spacingDp > 0) return;
  const kids = Array.from(el.children);
  if (kids.length <= 1) return;
  kids.forEach(child => {
    const r = child.style.borderRadius;
    if (!r || r === '0' || r === '0px') return;
    child.style.borderRadius = '0';
  });
}

function applyBase(el, n) {
  // Default min-width/height to 0 so flex/grid children don't force their
  // parent to grow to fit their min-content. Explicit minWidthDp/minHeightDp
  // below override these defaults.
  el.style.minWidth = '0';
  el.style.minHeight = '0';
  if (n.fillMaxWidth) el.style.width = '100%';
  if (n.fillMaxHeight) el.style.height = '100%';
  if (n.widthDp != null) el.style.width = n.widthDp + 'px';
  if (n.heightDp != null) el.style.height = n.heightDp + 'px';
  if (n.minWidthDp != null) el.style.minWidth = n.minWidthDp + 'px';
  if (n.maxWidthDp != null) el.style.maxWidth = n.maxWidthDp + 'px';
  if (n.minHeightDp != null) el.style.minHeight = n.minHeightDp + 'px';
  const pt = n.paddingTopDp    ?? n.paddingVerticalDp   ?? n.paddingDp ?? 0;
  const pr = n.paddingEndDp    ?? n.paddingHorizontalDp ?? n.paddingDp ?? 0;
  const pb = n.paddingBottomDp ?? n.paddingVerticalDp   ?? n.paddingDp ?? 0;
  const pl = n.paddingStartDp  ?? n.paddingHorizontalDp ?? n.paddingDp ?? 0;
  if (pt || pr || pb || pl) el.style.padding = pt+'px '+pr+'px '+pb+'px '+pl+'px';
  const r = n.cornerRadiusDp ?? (n.backgroundColor ? 20 : 0);
  if (n.backgroundColor) {
    const c = toCSS(n.backgroundColor);
    if (c) el.style.backgroundColor = c;
    el.style.borderRadius = r + 'px';
    el.style.overflow = 'hidden';
  } else if (n.cornerRadiusDp != null) {
    el.style.borderRadius = n.cornerRadiusDp + 'px';
  }
  if (n.alpha != null) el.style.opacity = String(Math.max(0, Math.min(1, n.alpha)));
  if (n.weight != null) {
    // Compose's Modifier.weight() passes a tight maxWidth to the child and
    // silently clamps any subsequent widthIn(min=...) to that maxWidth, so
    // minWidthDp on a weighted child does not actually guarantee a rendered
    // minimum width on-device - it only feeds shouldCollapseRow(). CSS
    // flexbox does the opposite: min-width wins over flex distribution and
    // bumps the weighted child up to minWidthDp, which made the preview look
    // spacious where the device wraps tightly. Force min-width back to 0 so
    // the weight share is what gets rendered, matching Compose. The
    // minWidthDp value is still recorded on the row's dataset.row.mw array
    // (see the row case in mkNode below) so collapse detection still uses it.
    el.style.flex = n.weight + ' 1 0px';
    el.style.minWidth = '0';
  }
}

function mkNode(n, dark, path) {
  const base = dark ? '#FFFFFF' : '#333333';
  if (!path) path = [];

  if (n.type === 'image') {
    const w = document.createElement('div');
    applyBase(w, n);
    w.dataset.prevpath = JSON.stringify(path);
    w.style.overflow = 'hidden';
    if (n.aspectRatio) w.style.aspectRatio = String(n.aspectRatio);
    if (n.actionUrl) w.classList.add('lcg-act');
    const img = document.createElement('img');
    img.src = n.imageUrl || '';
    img.alt = n.contentDescription || '';
    img.style.cssText = 'display:block;width:100%;height:100%';
    img.style.objectFit = SC[n.contentScale] || 'cover';
    w.appendChild(img);
    return w;
  }

  const el = document.createElement('div');
  applyBase(el, n);
  el.dataset.prevpath = JSON.stringify(path);
  if (n.actionUrl) el.classList.add('lcg-act');

  switch (n.type) {
    case 'box': {
      el.style.display = 'grid';
      el.style.gridTemplateAreas = '"s"';
      el.style.placeItems = CA[n.contentAlignment] || 'start start';
      (n.children || []).forEach((c, i) => {
        const ce = mkNode(c, dark, path.concat(i));
        ce.style.gridArea = 's';
        if (c.fillMaxHeight) ce.style.alignSelf = 'stretch';
        if (c.fillMaxWidth) { ce.style.justifySelf = 'stretch'; ce.style.width = '100%'; }
        el.appendChild(ce);
      });
      break;
    }
    case 'column': {
      // applyBase already sets min-width/min-height to 0 (or to explicit
      // minWidthDp/minHeightDp), so the column shrinks to its grid track
      // when stacked inside a Box and verticalArrangement-bottom content
      // stays inside the parent rather than overflowing.
      el.style.cssText += ';display:flex;flex-direction:column';
      if (n.spacingDp) el.style.gap = n.spacingDp + 'px';
      el.style.justifyContent = ARR[n.verticalArrangement] || 'flex-start';
      el.style.alignItems = ARR[n.horizontalAlignment] || 'flex-start';
      (n.children || []).forEach((c, i) => el.appendChild(mkNode(c, dark, path.concat(i))));
      trimChildCorners(el, n, 'column');
      break;
    }
    case 'row': {
      el.style.cssText += ';display:flex;flex-direction:row;flex-wrap:nowrap';
      if (n.spacingDp) el.style.gap = n.spacingDp + 'px';
      el.style.justifyContent = ARR[n.horizontalArrangement] || 'flex-start';
      el.style.alignItems = ARR[n.verticalAlignment] || 'flex-start';
      (n.children || []).forEach((c, i) => el.appendChild(mkNode(c, dark, path.concat(i))));
      trimChildCorners(el, n, 'row');
      el.dataset.row = JSON.stringify({
        cb: n.collapseBelowDp,
        sp: n.spacingDp || 0,
        mw: (n.children || []).map(c => c.minWidthDp || 0),
      });
      break;
    }
    case 'text': {
      el.style.minWidth = '0';
      el.style.wordBreak = 'break-word';
      el.style.whiteSpace = 'pre-wrap';
      const t = TYP[n.style] || TYP.bodyMedium;
      el.style.fontSize = t.fs; el.style.fontWeight = t.fw;
      el.style.letterSpacing = t.ls; el.style.lineHeight = t.lh;
      if (n.fontSizeSp) el.style.fontSize = n.fontSizeSp + 'px';
      if (n.fontWeight) el.style.fontWeight = FW[n.fontWeight] || n.fontWeight;
      if (n.fontStyle === 'italic') el.style.fontStyle = 'italic';
      if (n.textAlign) {
        const ta = n.textAlign === 'centre' ? 'center'
          : (n.textAlign === 'right' || n.textAlign === 'end') ? 'right' : n.textAlign;
        el.style.textAlign = ta;
      }
      const c = n.color ? toCSS(n.color) : base;
      if (c) el.style.color = c;
      el.textContent = n.text || '';
      break;
    }
    case 'spacer': {
      el.style.display = 'block'; el.style.flexShrink = '0';
      if (n.widthDp != null && n.heightDp != null) { /* already applied */ }
      else if (n.spacingDp != null) el.style.height = n.spacingDp + 'px';
      else { el.style.width = '8px'; el.style.height = '8px'; }
      break;
    }
    case 'divider': {
      el.style.cssText += ';width:100%;height:1px;border:none';
      const dc = n.color ? toCSS(n.color) : (dark ? '#49454F' : '#CAC4D0');
      if (dc) el.style.backgroundColor = dc;
      break;
    }
    case 'markdown': {
      el.style.minWidth = '0'; el.style.wordBreak = 'break-word';
      el.classList.add('lcg-md');
      el.style.color = base;
      if (typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined') {
        el.innerHTML = DOMPurify.sanitize(marked.parse(n.text || ''));
      } else {
        const p = document.createElement('pre');
        p.style.whiteSpace = 'pre-wrap'; p.textContent = n.text || '';
        el.appendChild(p);
      }
      break;
    }
    default: break;
  }
  return el;
}

function collapseRows(container) {
  container.querySelectorAll('[data-row]').forEach(rowEl => {
    try {
      const d = JSON.parse(rowEl.dataset.row);
      const rw = rowEl.clientWidth;
      // Only collapse on an explicit collapseBelowDp threshold.
      // Compose Row never auto-flips direction based on child minWidth -
      // weighted children just get cramped (or text wraps) when space runs out.
      const collapse = !!(d.cb && rw <= d.cb);
      const wasCollapsed = rowEl.dataset.collapsed === '1';
      if (collapse && !wasCollapsed) {
        rowEl.style.flexDirection = 'column';
        rowEl.querySelectorAll(':scope > *').forEach(c => {
          if (c.style.flex || c.style.width) {
            c.dataset.savedFlex = c.style.flex || '';
            c.dataset.savedWidth = c.style.width || '';
          }
          c.style.flex = '';
          c.style.width = '100%';
        });
        rowEl.dataset.collapsed = '1';
      } else if (!collapse && wasCollapsed) {
        rowEl.style.flexDirection = 'row';
        rowEl.querySelectorAll(':scope > *').forEach(c => {
          if (c.dataset.savedFlex !== undefined) {
            c.style.flex = c.dataset.savedFlex;
            c.style.width = c.dataset.savedWidth;
            delete c.dataset.savedFlex;
            delete c.dataset.savedWidth;
          } else {
            c.style.width = '';
          }
        });
        delete rowEl.dataset.collapsed;
      }
    } catch (e) {}
  });
}

/* ── TREE ────────────────────────────────────────────────── */
const CONTAINERS = new Set(['box', 'column', 'row']);
const ALL_TYPES  = ['box', 'column', 'row', 'text', 'image', 'markdown', 'spacer', 'divider'];

function renderTree() {
  const el = document.getElementById('lcg-tree');
  const rootBtn = document.getElementById('lcg-add-root-btn');
  if (!S.spec) {
    el.innerHTML = '<div class="lcg-tree-empty">No spec loaded - add a root node to start.</div>';
    rootBtn.style.display = '';
    return;
  }
  rootBtn.style.display = 'none';
  el.innerHTML = '';
  walkTree(S.spec, [], el);
  const sel = el.querySelector('.lcg-sel');
  if (sel) sel.scrollIntoView({ block: 'nearest' });
}

function walkTree(n, path, container) {
  const depth = path.length;
  const key = pk(path);
  const isCollapsed = S.collapsed.has(key);
  const hasKids = !!(n.children && n.children.length);
  const isSel = S.sel !== null && pk(S.sel) === key;

  const row = document.createElement('div');
  row.className = 'lcg-tree-node' + (isSel ? ' lcg-sel' : '');
  row.dataset.path = key;
  if (depth > 0) { row.draggable = true; row.dataset.draggable = '1'; }

  const ind = document.createElement('span');
  ind.className = 'lcg-n-indent';
  ind.style.paddingLeft = (depth * 16 + 6) + 'px';
  row.appendChild(ind);

  const tog = document.createElement('span');
  tog.className = 'lcg-n-tog';
  tog.dataset.tpath = key;
  tog.textContent = hasKids ? (isCollapsed ? '▶' : '▼') : '·';
  row.appendChild(tog);

  const type = document.createElement('span');
  type.className = 'lcg-n-type';
  type.textContent = n.type;
  row.appendChild(type);

  const friendly = document.createElement('span');
  friendly.className = 'lcg-n-friendly';
  friendly.textContent = friendlyName(n);
  row.appendChild(friendly);

  const prev = document.createElement('span');
  prev.className = 'lcg-n-prev';
  if (n.type === 'text' || n.type === 'markdown') prev.textContent = (n.text || '').slice(0, 22);
  else if (n.type === 'image') prev.textContent = n.imageUrl ? '↗ image' : '';
  row.appendChild(prev);

  const acts = document.createElement('span');
  acts.className = 'lcg-n-acts';

  if (CONTAINERS.has(n.type)) {
    const ab = btn('+', 'Add child'); ab.dataset.addp = key; acts.appendChild(ab);
  }
  if (depth > 0) {
    const ub = btn('↑', 'Move up');   ub.dataset.mvup = key;  acts.appendChild(ub);
    const db = btn('↓', 'Move down'); db.dataset.mvdn = key;  acts.appendChild(db);
  }
  const xb = btn('✕', depth === 0 ? 'Clear all' : 'Delete');
  xb.classList.add('lcg-n-del'); xb.dataset.del = key;
  acts.appendChild(xb);

  row.appendChild(acts);
  container.appendChild(row);

  if (hasKids && !isCollapsed) {
    n.children.forEach((c, i) => walkTree(c, [...path, i], container));
  }
}

function btn(txt, title) {
  const b = document.createElement('button');
  b.className = 'lcg-n-btn'; b.title = title; b.textContent = txt;
  return b;
}

/* ── PROPERTIES ─────────────────────────────────────────── */
const STYLES_OPTS = ['','displayLarge','displayMedium','displaySmall',
  'headlineLarge','headlineMedium','headlineSmall',
  'titleLarge','titleMedium','titleSmall',
  'bodyLarge','bodyMedium','bodySmall',
  'labelLarge','labelMedium','labelSmall'];

function renderProps() {
  const el = document.getElementById('lcg-props');
  const title = document.getElementById('lcg-props-title');
  if (S.sel === null || !S.spec) {
    title.textContent = 'Properties';
    el.innerHTML = '<div class="lcg-props-empty">Select a node to edit its properties.</div>';
    return;
  }
  const n = gn(S.spec, S.sel);
  if (!n) { el.innerHTML = '<div class="lcg-props-empty">Node not found.</div>'; return; }
  title.textContent = 'Properties';
  el.innerHTML = '';
  const form = document.createElement('div');
  form.className = 'lcg-props-form';

  // Type selector
  const tr = document.createElement('div'); tr.className = 'lcg-type-row';
  const tlbl = document.createElement('label'); tlbl.htmlFor = 'lcg-pf-type'; tlbl.textContent = 'Type';
  tr.appendChild(tlbl);
  const ts = document.createElement('select');
  ts.id = 'lcg-pf-type'; ts.name = 'type'; ts.dataset.field = 'type';
  ALL_TYPES.forEach(t => {
    const o = document.createElement('option');
    o.value = t; o.textContent = t;
    if (t === n.type) o.selected = true;
    ts.appendChild(o);
  });
  tr.appendChild(ts); form.appendChild(tr);

  // Content fields
  const cf = contentFields(n);
  if (cf.length) form.appendChild(mkSec('Content', cf, n, 'content'));

  // Layout fields
  const lf = layoutFields(n);
  if (lf.length) form.appendChild(mkSec('Layout', lf, n, 'layout'));

  // Inner space (was "Padding") - beginner sees only "All sides"; advanced sees the
  // per-side breakdown.
  form.appendChild(mkSec('Inner space', [
    {f:'paddingDp',          l:'All sides (dp)',   bL:'All sides',         t:'number'},
    {f:'paddingHorizontalDp',l:'Horizontal (dp)',  t:'number', adv:true},
    {f:'paddingVerticalDp',  l:'Vertical (dp)',    t:'number', adv:true},
    {f:'paddingStartDp',     l:'Start (dp)',       t:'number', adv:true},
    {f:'paddingTopDp',       l:'Top (dp)',         t:'number', adv:true},
    {f:'paddingEndDp',       l:'End (dp)',         t:'number', adv:true},
    {f:'paddingBottomDp',    l:'Bottom (dp)',      t:'number', adv:true},
  ], n, 'padding'));

  // Appearance
  form.appendChild(mkSec('Appearance', [
    {f:'backgroundColor', l:'Background colour', bL:'Card colour',           t:'color'},
    {f:'cornerRadiusDp',  l:'Corner radius (dp)', bL:'Rounded corners (dp)', t:'number'},
    {f:'alpha',           l:'Alpha (0–1)',  t:'number', step:'0.01', min:'0', max:'1', adv:true},
  ], n, 'appearance'));

  // Action - promoted to its own section so it's discoverable for every
  // node type (text, markdown, image, and containers can all be tappable).
  form.appendChild(mkSec('Action', [
    {f:'actionUrl', l:'Action URL (tap target)', bL:'Open this link when tapped', t:'url'},
  ], n, 'action'));

  el.appendChild(form);
}

function contentFields(n) {
  switch (n.type) {
    case 'text': return [
      {f:'text',      l:'Text',        t:'textarea'},
      {f:'style',     l:'Style',       bL:'Text size',  t:'select', opts: STYLES_OPTS},
      {f:'color',     l:'Colour',      bL:'Text colour', t:'color'},
      {f:'textAlign', l:'Text align',  t:'select', opts:['','start','center','end','justify']},
      {f:'fontWeight',l:'Font weight', t:'select', opts:['','light','medium','semi_bold','bold'], adv:true},
      {f:'fontStyle', l:'Font style',  t:'select', opts:['','italic'], adv:true},
      {f:'fontSizeSp',l:'Font size (sp)', t:'number', adv:true},
    ];
    case 'markdown': return [{f:'text', l:'Markdown text', t:'textarea'}];
    case 'image': return [
      {f:'imageUrl',          l:'Image URL',          bL:'Image URL',           t:'text'},
      {f:'contentDescription',l:'Content description',bL:'Description (for screen readers)', t:'text'},
      {f:'aspectRatio',       l:'Aspect ratio',       bL:'Width-to-height ratio', t:'number', step:'0.01'},
      {f:'contentScale',      l:'Content scale',      bL:'How to fit', t:'select',
        opts:['','crop','fit','fill_bounds','fill_width','fill_height','inside','none']},
    ];
    case 'divider': return [{f:'color', l:'Colour', bL:'Line colour', t:'color'}];
    default: return [];
  }
}

function layoutFields(n) {
  const base = [
    {f:'fillMaxWidth', l:'Fill max width',  bL:'Stretch to full width',   t:'checkbox'},
    {f:'fillMaxHeight',l:'Fill max height', bL:'Stretch to full height',  t:'checkbox'},
    {f:'widthDp',      l:'Width (dp)',      bL:'Fixed width (dp)',        t:'number', adv:true},
    {f:'heightDp',     l:'Height (dp)',     bL:'Fixed height (dp)',       t:'number', adv:true},
    {f:'minWidthDp',   l:'Min width (dp)',   t:'number', adv:true},
    {f:'maxWidthDp',   l:'Max width (dp)',   t:'number', adv:true},
    {f:'minHeightDp',  l:'Min height (dp)',  t:'number', adv:true},
    {f:'weight',       l:'Weight',          bL:'Share of row (1=equal)',  t:'number', step:'0.1'},
  ];
  if (n.type === 'spacer') return [
    {f:'spacingDp',l:'Spacing (dp)', bL:'Size (dp)',  t:'number'},
    {f:'widthDp',  l:'Width (dp)',   t:'number', adv:true},
    {f:'heightDp', l:'Height (dp)',  t:'number', adv:true},
  ];
  const extras = {
    box:    [{f:'contentAlignment', l:'Content alignment', bL:'Where to put content', t:'select',
               opts:['','top_start','top_center','top_end','center_start','center','center_end','bottom_start','bottom_center','bottom_end']}],
    column: [
      {f:'spacingDp',           l:'Spacing (dp)',          bL:'Gap between items (dp)', t:'number'},
      {f:'verticalArrangement', l:'Vertical arrangement',  bL:'Stack from',  t:'select',
        opts:['','top','center','bottom','space_between','space_around','space_evenly']},
      {f:'horizontalAlignment', l:'Horizontal alignment',  bL:'Align items', t:'select',
        opts:['','start','center','end']},
    ],
    row: [
      {f:'spacingDp',             l:'Spacing (dp)',           bL:'Gap between items (dp)', t:'number'},
      {f:'horizontalArrangement', l:'Horizontal arrangement', bL:'Spread items',  t:'select',
        opts:['','start','center','end','space_between','space_around','space_evenly']},
      {f:'verticalAlignment',     l:'Vertical alignment',     bL:'Align items',   t:'select',
        opts:['','top','center','bottom']},
      {f:'collapseBelowDp',       l:'Collapse below (dp)',    bL:'Stack vertically below width (dp)', t:'number'},
    ],
  };
  return [...base, ...(extras[n.type] || [])];
}

function mkSec(title, fields, n, key) {
  const sec = document.createElement('div'); sec.className = 'lcg-sec';
  const isOpen = S.secState[key] !== false;

  const hd = document.createElement('div'); hd.className = 'lcg-sec-hd'; hd.dataset.sec = key;
  hd.innerHTML = '<span>' + title + '</span><span class="lcg-sec-tog">' + (isOpen ? '▼' : '▶') + '</span>';
  sec.appendChild(hd);

  const body = document.createElement('div'); body.className = 'lcg-sec-body';
  if (!isOpen) body.style.display = 'none';

  fields.forEach(fd => {
    const div = document.createElement('div');
    div.className = 'lcg-f' + (fd.adv ? ' lcg-f-advanced' : '');
    // Plain-English label for beginner mode if provided, else the existing label
    const labelText = (!S.advanced && fd.bL) ? fd.bL : fd.l;
    // Unique form-field id per section + field, so the visible label can
    // bind via for/id (a11y) and the field has both id and name attributes
    // for assistive tech and DevTools form-field validation.
    const fieldId = 'lcg-pf-' + key + '-' + fd.f;

    if (fd.t === 'checkbox') {
      const lbl = document.createElement('label'); lbl.className = 'lcg-cb-label';
      lbl.htmlFor = fieldId;
      const cb = document.createElement('input'); cb.type = 'checkbox';
      cb.id = fieldId; cb.name = fd.f;
      cb.checked = !!n[fd.f]; cb.dataset.field = fd.f;
      lbl.appendChild(cb);
      lbl.appendChild(document.createTextNode(' ' + labelText));
      div.appendChild(lbl);
    } else if (fd.t === 'color') {
      const lbl = document.createElement('label');
      lbl.htmlFor = fieldId; lbl.textContent = labelText;
      div.appendChild(lbl);
      const row = document.createElement('div'); row.className = 'lcg-color-row';
      const sw = document.createElement('span'); sw.className = 'lcg-swatch';
      sw.style.backgroundColor = toCSS(n[fd.f]) || 'transparent';
      row.appendChild(sw);
      const inp = document.createElement('input'); inp.type = 'text';
      inp.id = fieldId; inp.name = fd.f;
      inp.value = n[fd.f] || ''; inp.placeholder = '#AARRGGBB or #RRGGBB';
      inp.dataset.field = fd.f; inp.dataset.swatch = '1';
      row.appendChild(inp); div.appendChild(row);
    } else if (fd.t === 'select') {
      const lbl = document.createElement('label');
      lbl.htmlFor = fieldId; lbl.textContent = labelText;
      div.appendChild(lbl);
      const sel = document.createElement('select');
      sel.id = fieldId; sel.name = fd.f; sel.dataset.field = fd.f;
      (fd.opts || []).forEach(o => {
        const op = document.createElement('option');
        op.value = o; op.textContent = o || '- none -';
        if (o === (n[fd.f] || '')) op.selected = true;
        sel.appendChild(op);
      });
      div.appendChild(sel);
    } else if (fd.t === 'textarea') {
      const lbl = document.createElement('label');
      lbl.htmlFor = fieldId; lbl.textContent = labelText;
      div.appendChild(lbl);
      const ta = document.createElement('textarea');
      ta.id = fieldId; ta.name = fd.f; ta.value = n[fd.f] || '';
      ta.dataset.field = fd.f; div.appendChild(ta);
    } else {
      const lbl = document.createElement('label');
      lbl.htmlFor = fieldId; lbl.textContent = labelText;
      div.appendChild(lbl);
      const inp = document.createElement('input'); inp.type = fd.t || 'text';
      inp.id = fieldId; inp.name = fd.f;
      inp.value = n[fd.f] != null ? n[fd.f] : '';
      inp.dataset.field = fd.f;
      if (fd.step != null) inp.step = fd.step;
      if (fd.min  != null) inp.min  = fd.min;
      if (fd.max  != null) inp.max  = fd.max;
      // Auto-apply min=0 for size / padding / radius / spacing / typography
      // numeric fields (and weight). Without this, a11y and form-validation
      // tools see number controls with no declared min, even though the
      // editor's intent is non-negative.
      if (fd.t === 'number' && fd.min == null &&
          (NON_NEG_NUMERIC.has(fd.f) || fd.f === 'weight')) {
        inp.min = '0';
      }
      div.appendChild(inp);
    }
    body.appendChild(div);
  });

  sec.appendChild(body);
  return sec;
}

/* ── PREVIEW ─────────────────────────────────────────────── */
let roObs = null;

function renderPreview() {
  const card = document.getElementById('lcg-card');
  if (roObs) { roObs.disconnect(); roObs = null; }
  // The wrapper acts as the Material 3 surface card the live app
  // renders the spec inside. If the root spec node already has its
  // own backgroundColor it IS the visible card and the wrapper hides
  // (no second visible surface). Otherwise the wrapper provides the
  // surface so a multi-section spec reads as one card.
  const rootHasOwnSurface = !!(S.spec && S.spec.backgroundColor);
  card.className = 'lcg-card-wrap'
    + (S.dark ? ' lcg-dark' : '')
    + (rootHasOwnSurface ? ' lcg-surface-off' : '');
  card.innerHTML = '';

  if (!S.spec) {
    const empty = document.createElement('div');
    empty.className = 'lcg-empty-state';
    empty.innerHTML = '<h3>Nothing here yet</h3><p>Pick a template to start with, or add a single component.</p>';
    const btns = document.createElement('div'); btns.className = 'lcg-empty-state-buttons';
    const tplBtn = document.createElement('button'); tplBtn.className = 'lcg-primary-btn'; tplBtn.type = 'button';
    tplBtn.textContent = 'Start from a template'; tplBtn.addEventListener('click', () => openTplModal());
    const cmpBtn = document.createElement('button'); cmpBtn.className = 'lcg-secondary-btn'; cmpBtn.type = 'button';
    cmpBtn.textContent = '+ Add a component'; cmpBtn.addEventListener('click', () => openCmpModal(null));
    btns.appendChild(tplBtn); btns.appendChild(cmpBtn);
    empty.appendChild(btns);
    card.appendChild(empty);
    return;
  }
  try {
    card.appendChild(mkNode(S.spec, S.dark, []));
    collapseRows(card);
    roObs = new ResizeObserver(() => collapseRows(card));
    roObs.observe(card);
  } catch (e) {
    card.innerHTML = '';
    const errDiv = document.createElement('div');
    errDiv.style.cssText = 'color:#c30000;font-family:Roboto,sans-serif;font-size:13px';
    errDiv.textContent = 'Render error: ' + e.message;
    card.appendChild(errDiv);
  }
}

/* ── JSON ────────────────────────────────────────────────── */
function updateJSON() {
  const out  = document.getElementById('lcg-json-out');
  const ctr  = document.getElementById('lcg-counter');
  const warn = document.getElementById('lcg-cnt-warn');
  const copyBtn = document.getElementById('lcg-copy-btn');
  const dlBtn   = document.getElementById('lcg-dl-btn');
  if (!S.spec) {
    out.value = ''; ctr.textContent = '0 chars';
    ctr.className = 'lcg-cnt-green'; warn.textContent = '';
    if (copyBtn) { copyBtn.disabled = true; copyBtn.title = 'Nothing to copy'; }
    if (dlBtn)   { dlBtn.disabled = true;   dlBtn.title   = 'Nothing to download'; }
    return;
  }
  const json = JSON.stringify(S.spec);
  out.value = json;
  const len = json.length;
  const fmt = len.toLocaleString();
  let tooBig = false;
  if (len <= 9999) {
    ctr.textContent = fmt + ' chars'; ctr.className = 'lcg-cnt-green'; warn.textContent = '';
  } else if (len <= 20000) {
    ctr.textContent = fmt + ' chars'; ctr.className = 'lcg-cnt-amber';
    warn.textContent = 'Large spec - may approach delivery limits depending on your EMM.';
  } else {
    ctr.textContent = fmt + ' chars - exceeds recommended limit';
    ctr.className = 'lcg-cnt-red';
    warn.textContent = 'Specs over 20,000 chars may not deliver reliably. Copy and download are disabled - trim the spec to continue.';
    tooBig = true;
  }
  if (copyBtn) {
    copyBtn.disabled = tooBig;
    copyBtn.title = tooBig ? 'Spec exceeds 20,000 chars - trim before copying' : '';
  }
  if (dlBtn) {
    dlBtn.disabled = tooBig;
    dlBtn.title = tooBig ? 'Spec exceeds 20,000 chars - trim before downloading' : '';
  }
}

function renderAll() { renderTree(); renderProps(); renderPreview(); updateJSON(); }

/* ── IMPORT ─────────────────────────────────────────────── */
// Enum-valued fields and the exact set of values the editor exposes for
// each. Anything outside this set would import successfully but then be
// silently invisible (the dropdown falls back to "- none -" because the
// stored value matches no option), letting the spec drift away from
// what the UI shows. Reject on import.
const ENUM_OPTIONS = {
  contentAlignment:        ['top_start','top_center','top_end','center_start','center','center_end','bottom_start','bottom_center','bottom_end'],
  verticalArrangement:     ['top','center','bottom','space_between','space_around','space_evenly'],
  horizontalAlignment:     ['start','center','end'],
  horizontalArrangement:   ['start','center','end','space_between','space_around','space_evenly'],
  verticalAlignment:       ['top','center','bottom'],
  contentScale:            ['crop','fit','fill_bounds','fill_width','fill_height','inside','none'],
  style:                   ['displayLarge','displayMedium','displaySmall','headlineLarge','headlineMedium','headlineSmall','titleLarge','titleMedium','titleSmall','bodyLarge','bodyMedium','bodySmall','labelLarge','labelMedium','labelSmall'],
  fontWeight:              ['light','medium','semi_bold','bold'],
  fontStyle:               ['italic'],
  textAlign:               ['start','center','end','justify'],
};

// Layout / size / radius / padding / spacing / typography numbers that
// must be >= 0 to be meaningful. Negative values were accepted before
// and rendered through to the JSON output even though the editor's
// number controls present these as non-negative ranges. Reject on
// import so the form never holds an internally inconsistent state.
const NON_NEG_NUMERIC = new Set([
  'widthDp','heightDp','minWidthDp','maxWidthDp','minHeightDp','maxHeightDp',
  'paddingDp','paddingHorizontalDp','paddingVerticalDp',
  'paddingStartDp','paddingTopDp','paddingEndDp','paddingBottomDp',
  'cornerRadiusDp','spacingDp','collapseBelowDp','fontSizeSp','aspectRatio',
]);

function validateNode(n, path) {
  const where = path.length ? ' at children[' + path.join('][') + ']' : '';
  if (!n || typeof n !== 'object' || Array.isArray(n)) {
    return (path.length ? 'Node' : 'Root') + where + ' must be a JSON object.';
  }
  if (!n.type || typeof n.type !== 'string') {
    return (path.length ? 'Node' : 'Root') + where + ' must have a "type" field.';
  }
  if (!ALL_TYPES.includes(n.type)) {
    return 'Unknown type "' + n.type + '"' + where + '. Must be one of: ' + ALL_TYPES.join(', ') + '.';
  }
  // Per-field value checks: enums must be one of the editor's options,
  // size/padding/radius numbers must be >= 0, alpha must be 0..1.
  for (const k in n) {
    if (k === 'type' || k === 'children') continue;
    const v = n[k];
    if (v == null) continue;
    if (ENUM_OPTIONS[k] && !ENUM_OPTIONS[k].includes(v)) {
      return 'Node' + where + ' has unknown value "' + v + '" for "' + k +
        '". Valid options: ' + ENUM_OPTIONS[k].join(', ') + '.';
    }
    if (NON_NEG_NUMERIC.has(k)) {
      if (typeof v !== 'number' || !isFinite(v) || v < 0) {
        return 'Node' + where + ' has invalid value "' + v + '" for "' + k +
          '". Must be a number >= 0.';
      }
    }
    if (k === 'alpha') {
      if (typeof v !== 'number' || !isFinite(v) || v < 0 || v > 1) {
        return 'Node' + where + ' has invalid value "' + v + '" for "alpha".' +
          ' Must be a number between 0 and 1.';
      }
    }
    if (k === 'weight') {
      if (typeof v !== 'number' || !isFinite(v) || v < 0) {
        return 'Node' + where + ' has invalid value "' + v + '" for "weight".' +
          ' Must be a number >= 0.';
      }
    }
  }
  if (n.children !== undefined) {
    if (!Array.isArray(n.children)) {
      return 'Node' + where + ' has non-array "children".';
    }
    if (!CONTAINERS.has(n.type)) {
      return 'Node' + where + ' (type "' + n.type + '") cannot have children.';
    }
    for (let i = 0; i < n.children.length; i++) {
      const e = validateNode(n.children[i], path.concat(i));
      if (e) return e;
    }
  }
  return null;
}

function parseImport(str) {
  let p;
  try { p = JSON.parse(str.trim()); } catch (e) { return { err: 'Invalid JSON: ' + e.message }; }
  const err = validateNode(p, []);
  if (err) return { err };
  return { spec: p };
}

function closeImportModal() {
  document.getElementById('lcg-import-modal').classList.add('lcg-modal-off');
  document.getElementById('lcg-import-ta').value = '';
  const e = document.getElementById('lcg-import-err');
  e.className = 'lcg-err-off'; e.textContent = '';
}

/* ── TEMPLATE & COMPONENT MODALS ─────────────────────────── */
function openTplModal() {
  const grid = document.getElementById('lcg-tpl-grid');
  grid.innerHTML = '';
  TEMPLATES.forEach(t => {
    const card = document.createElement('button'); card.type = 'button'; card.className = 'lcg-tpl-card';
    card.dataset.tplId = t.id;
    card.innerHTML =
      '<div class="lcg-tpl-icon">' + t.icon + '</div>' +
      '<div class="lcg-tpl-name">' + t.name + '</div>' +
      '<div class="lcg-tpl-desc">' + t.desc + '</div>';
    card.addEventListener('click', () => {
      const spec = t.spec();
      const r = parseImport(JSON.stringify(spec));
      if (r.err) { alert(r.err); return; }
      S.spec = r.spec; S.sel = null; S.collapsed.clear();
      renderAll(); closeTplModal();
    });
    grid.appendChild(card);
  });
  document.getElementById('lcg-tpl-modal').classList.remove('lcg-modal-off');
}

function closeTplModal() {
  document.getElementById('lcg-tpl-modal').classList.add('lcg-modal-off');
}

function openCmpModal(targetPath) {
  // targetPath null means "add to root or replace empty spec"
  S.cmpTarget = targetPath;
  const grid = document.getElementById('lcg-cmp-grid');
  const hint = document.getElementById('lcg-cmp-hint');
  grid.innerHTML = '';
  if (!S.spec) {
    hint.textContent = 'Add your first component. It will become the root of the card.';
  } else if (targetPath === null || (Array.isArray(targetPath) && targetPath.length === 0)) {
    hint.textContent = 'Add a new component at the top level of the card.';
  } else {
    const parent = gn(S.spec, targetPath);
    hint.textContent = 'Add a component inside ' + (parent ? friendlyName(parent) : 'this group') + '.';
  }
  COMPONENTS.forEach(c => {
    const card = document.createElement('button'); card.type = 'button'; card.className = 'lcg-cmp-card';
    if (c.advanced) card.dataset.advanced = '1';
    card.innerHTML =
      '<div class="lcg-cmp-icon">' + c.icon + '</div>' +
      '<div class="lcg-cmp-name">' + c.name + '</div>' +
      '<div class="lcg-cmp-desc">' + c.desc + '</div>';
    card.addEventListener('click', () => insertComponent(c));
    grid.appendChild(card);
  });
  document.getElementById('lcg-cmp-modal').classList.remove('lcg-modal-off');
}

function closeCmpModal() {
  document.getElementById('lcg-cmp-modal').classList.add('lcg-modal-off');
  S.cmpTarget = null;
}

function insertComponent(cmp) {
  const node = cmp.spec();
  // No spec yet: this becomes the root, wrapped in a column if it's a leaf
  if (!S.spec) {
    if (CONTAINERS.has(node.type)) {
      S.spec = node;
    } else {
      S.spec = { type: 'column', fillMaxWidth: true, spacingDp: 12, children: [node] };
    }
    S.sel = [];
    closeCmpModal(); renderAll(); return;
  }
  // Spec exists. If we have a target path that's a container, append.
  // If target is null or the root isn't a container, append to root if root is a container,
  // otherwise wrap root in a column.
  const target = S.cmpTarget;
  let parentPath;
  if (target && Array.isArray(target)) {
    const tNode = gn(S.spec, target);
    if (tNode && CONTAINERS.has(tNode.type)) parentPath = target;
  }
  if (!parentPath) {
    // Default: append to root
    if (CONTAINERS.has(S.spec.type)) {
      parentPath = [];
    } else {
      // Wrap existing root in a column
      S.spec = { type: 'column', fillMaxWidth: true, spacingDp: 12, children: [S.spec] };
      parentPath = [];
    }
  }
  const par = gn(S.spec, parentPath);
  if (!par.children) par.children = [];
  par.children.push(node);
  S.sel = parentPath.concat(par.children.length - 1);
  closeCmpModal(); renderAll();
}

/* ── TYPE MENU ───────────────────────────────────────────── */
let menuPath = null;

function showMenu(anchor, forPath) {
  menuPath = forPath;
  const m = document.getElementById('lcg-type-menu');
  const r = anchor.getBoundingClientRect();
  m.style.top  = (r.bottom + window.scrollY + 4) + 'px';
  m.style.left = (r.left   + window.scrollX)     + 'px';
  m.innerHTML  = '';
  ALL_TYPES.forEach(t => {
    const d = document.createElement('div'); d.className = 'lcg-t-opt';
    d.textContent = t; d.dataset.mtype = t; m.appendChild(d);
  });
  m.classList.remove('lcg-menu-off');
  setTimeout(() => document.addEventListener('click', closeMenu, { once: true }), 0);
}

function closeMenu() { document.getElementById('lcg-type-menu').classList.add('lcg-menu-off'); menuPath = null; }

/* ── DRAG-DROP ───────────────────────────────────────────── */
let dragP = null;

function isAncestorPath(anc, desc) {
  if (anc.length >= desc.length) return false;
  for (let i = 0; i < anc.length; i++) if (anc[i] !== desc[i]) return false;
  return true;
}

function adjustPathAfterDelete(target, deleted) {
  if (deleted.length === 0) return target;
  const d = deleted.length - 1;
  if (target.length <= d) return target;
  for (let i = 0; i < d; i++) if (target[i] !== deleted[i]) return target;
  if (deleted[d] < target[d]) {
    const adj = target.slice();
    adj[d] = adj[d] - 1;
    return adj;
  }
  return target;
}

function setupDragDrop() {
  const tree = document.getElementById('lcg-tree');
  tree.addEventListener('dragstart', e => {
    const row = e.target.closest('.lcg-tree-node[data-draggable]');
    if (!row) return;
    dragP = JSON.parse(row.dataset.path);
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', row.dataset.path);
    setTimeout(() => { if (row.isConnected) row.style.opacity = '.4'; }, 0);
  });
  tree.addEventListener('dragend', e => {
    const row = e.target.closest('.lcg-tree-node');
    if (row) row.style.opacity = '';
    tree.querySelectorAll('.lcg-drag-over').forEach(r => r.classList.remove('lcg-drag-over'));
    dragP = null;
  });
  tree.addEventListener('dragover', e => {
    e.preventDefault(); e.dataTransfer.dropEffect = 'move';
    tree.querySelectorAll('.lcg-drag-over').forEach(r => r.classList.remove('lcg-drag-over'));
    const row = e.target.closest('.lcg-tree-node');
    if (row && dragP) row.classList.add('lcg-drag-over');
  });
  tree.addEventListener('dragleave', e => {
    const row = e.target.closest('.lcg-tree-node');
    if (row) row.classList.remove('lcg-drag-over');
  });
  tree.addEventListener('drop', e => {
    e.preventDefault();
    const row = e.target.closest('.lcg-tree-node');
    if (!row || !dragP) return;
    const tPath = JSON.parse(row.dataset.path);
    if (pk(dragP) === pk(tPath)) return;
    // prevent dropping onto own descendant
    if (isAncestorPath(dragP, tPath)) return;

    const tNode = gn(S.spec, tPath);
    if (!tNode) return;
    const dragNode = JSON.parse(JSON.stringify(gn(S.spec, dragP)));
    if (!dragNode) return;

    if (CONTAINERS.has(tNode.type)) {
      // Move into target container as last child.
      delNode(S.spec, dragP);
      const adjTarget = adjustPathAfterDelete(tPath, dragP);
      const par = gn(S.spec, adjTarget);
      if (par && CONTAINERS.has(par.type)) {
        if (!par.children) par.children = [];
        par.children.push(dragNode);
        S.sel = [...adjTarget, par.children.length - 1];
      }
    } else {
      // Reorder within same parent (target is a leaf - drop before it).
      const dp = dragP.slice(0, -1), tp = tPath.slice(0, -1);
      if (pk(dp) === pk(tp)) {
        const par = gn(S.spec, dp);
        if (par && par.children) {
          const fi = dragP[dragP.length - 1];
          const tiOrig = tPath[tPath.length - 1];
          const item = par.children.splice(fi, 1)[0];
          const ti = tiOrig > fi ? tiOrig - 1 : tiOrig;
          par.children.splice(ti, 0, item);
          S.sel = [...dp, ti];
        }
      }
    }
    renderAll();
  });
}

/* ── INIT ────────────────────────────────────────────────── */
/* Common Android device widths in dp - used to label the width slider
   so users know what their card looks like on a real screen. 416 is the
   Pixel 9 Pro XL, which is what the live MANAGED INFO app currently
   renders against, so that's the default. */
const DEVICE_WIDTHS = [
  { dp: 360, name: 'Pixel 9' },
  { dp: 384, name: 'Pixel 9 Pro' },
  { dp: 412, name: 'Galaxy / Pixel 9 Pro Fold (front)' },
  { dp: 416, name: 'Pixel 9 Pro XL' },
  { dp: 600, name: 'small tablet' },
];

function deviceLabelFor(dp) {
  let best = null, bestDiff = Infinity;
  for (const d of DEVICE_WIDTHS) {
    const diff = Math.abs(d.dp - dp);
    if (diff < bestDiff) { best = d; bestDiff = diff; }
  }
  return best && bestDiff <= 6 ? '(' + best.name + ')' : '';
}

function setWidth(w) {
  S.pw = Math.max(280, Math.min(700, parseInt(w) || 416));
  document.getElementById('lcg-phone').style.width = S.pw + 'px';
  document.getElementById('lcg-w-range').value = S.pw;
  document.getElementById('lcg-w-num').value   = S.pw;
  const dev = document.querySelector('.lcg-w-device');
  if (dev) dev.textContent = deviceLabelFor(S.pw);
  renderPreview();
}

function init() {
  setWidth(416);
  renderAll();

  // Templates modal
  document.getElementById('lcg-tpl-btn').addEventListener('click', openTplModal);
  document.getElementById('lcg-tpl-close').addEventListener('click', closeTplModal);
  document.getElementById('lcg-tpl-modal').addEventListener('click', e => {
    if (e.target === document.getElementById('lcg-tpl-modal')) closeTplModal();
  });

  // Components modal
  document.getElementById('lcg-add-cmp-btn').addEventListener('click', () => openCmpModal(null));
  document.getElementById('lcg-cmp-close').addEventListener('click', closeCmpModal);
  document.getElementById('lcg-cmp-modal').addEventListener('click', e => {
    if (e.target === document.getElementById('lcg-cmp-modal')) closeCmpModal();
  });

  // Advanced toggle - switches between beginner UI (templates + plain-English
  // labels) and the v1-style raw editor (full tree, every dp field exposed).
  const advCb = document.getElementById('lcg-adv-toggle');
  advCb.addEventListener('change', () => {
    S.advanced = advCb.checked;
    const root = document.getElementById('lcg');
    root.classList.toggle('lcg-advanced', S.advanced);
    root.classList.toggle('lcg-beginner', !S.advanced);
    renderAll();
  });

  // Inline preview clicks - clicking any rendered node selects it in the tree
  // and focuses the properties panel. Lets users edit by tapping what they
  // see rather than navigating the tree.
  document.getElementById('lcg-card').addEventListener('click', e => {
    // Don't intercept clicks on the empty-state buttons
    if (e.target.closest('.lcg-empty-state')) return;
    const target = e.target.closest('[data-prevpath]');
    if (!target) return;
    e.preventDefault();
    e.stopPropagation();
    const path = JSON.parse(target.dataset.prevpath);
    S.sel = path;
    renderTree();
    renderProps();
    document.getElementById('lcg-props').scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  });

  // Import modal
  document.getElementById('lcg-import-btn').addEventListener('click', () => {
    document.getElementById('lcg-import-modal').classList.remove('lcg-modal-off');
    document.getElementById('lcg-import-ta').focus();
  });
  document.getElementById('lcg-import-close').addEventListener('click',  closeImportModal);
  document.getElementById('lcg-import-cancel').addEventListener('click', closeImportModal);
  document.getElementById('lcg-import-modal').addEventListener('click', e => {
    if (e.target === document.getElementById('lcg-import-modal')) closeImportModal();
  });
  document.getElementById('lcg-import-ok').addEventListener('click', () => {
    const str = document.getElementById('lcg-import-ta').value;
    const r   = parseImport(str);
    const err = document.getElementById('lcg-import-err');
    if (r.err) {
      err.textContent = r.err; err.className = 'lcg-err';
    } else {
      S.spec = r.spec; S.sel = null; S.collapsed.clear();
      renderAll(); closeImportModal();
    }
  });

  // Dark toggle - flips the card's text-default colour and darkens the
  // surrounding "device surface" so the card visually sits on a dark
  // wallpaper rather than the light one.
  document.getElementById('lcg-dark-toggle').addEventListener('change', e => {
    S.dark = e.target.checked;
    document.getElementById('lcg-preview-scroll').classList.toggle('lcg-dark-surface', S.dark);
    renderPreview();
  });

  // Width
  document.getElementById('lcg-w-range').addEventListener('input',  e => setWidth(e.target.value));
  document.getElementById('lcg-w-num').addEventListener('change',   e => setWidth(e.target.value));

  // Add root
  document.getElementById('lcg-add-root-btn').addEventListener('click', e => {
    if (S.advanced) showMenu(e.target, []); else openCmpModal(null);
  });

  // Type menu
  document.getElementById('lcg-type-menu').addEventListener('click', e => {
    const item = e.target.closest('[data-mtype]');
    if (!item || menuPath === null) return;
    const type = item.dataset.mtype;
    const p = menuPath;
    if (p.length === 0 && !S.spec) {
      S.spec = { type }; S.sel = [];
    } else {
      const np = addChild(S.spec, p, type);
      if (np) S.sel = np;
    }
    renderAll(); closeMenu();
  });

  // Tree: clicks (delegated)
  document.getElementById('lcg-tree').addEventListener('click', e => {
    const row = e.target.closest('.lcg-tree-node');
    if (!row) return;
    const path = JSON.parse(row.dataset.path);

    // Toggle collapse
    if (e.target.dataset.tpath !== undefined) {
      const k = e.target.dataset.tpath;
      S.collapsed.has(k) ? S.collapsed.delete(k) : S.collapsed.add(k);
      renderTree(); return;
    }
    // Add child
    if (e.target.dataset.addp !== undefined) {
      e.stopPropagation();
      const addPath = JSON.parse(e.target.dataset.addp);
      if (S.advanced) {
        showMenu(e.target, addPath);
      } else {
        openCmpModal(addPath);
      }
      return;
    }
    // Move up
    if (e.target.dataset.mvup !== undefined) {
      e.stopPropagation();
      const np = moveNode(S.spec, JSON.parse(e.target.dataset.mvup), -1);
      if (np) S.sel = np; renderAll(); return;
    }
    // Move down
    if (e.target.dataset.mvdn !== undefined) {
      e.stopPropagation();
      const np = moveNode(S.spec, JSON.parse(e.target.dataset.mvdn), 1);
      if (np) S.sel = np; renderAll(); return;
    }
    // Delete
    if (e.target.dataset.del !== undefined) {
      e.stopPropagation();
      const dp = JSON.parse(e.target.dataset.del);
      if (dp.length === 0) {
        if (!confirm('Clear the entire spec?')) return;
        S.spec = null; S.sel = null;
      } else {
        const dk = pk(dp), sk = S.sel ? pk(S.sel) : null;
        if (sk && (sk === dk || sk.startsWith(dk.slice(0,-1) + ','))) {
          S.sel = dp.length > 1 ? dp.slice(0,-1) : [];
        }
        delNode(S.spec, dp);
        if (S.sel && pk(S.sel) === dk) S.sel = dp.length > 1 ? dp.slice(0,-1) : [];
      }
      renderAll(); return;
    }
    // Select
    S.sel = path; renderTree(); renderProps();
  });

  setupDragDrop();

  // Props: change/input (delegated)
  const propsEl = document.getElementById('lcg-props');
  function onPropChange(e) {
    const el = e.target;
    if (!el.dataset.field || S.sel === null || !S.spec) return;
    const n = gn(S.spec, S.sel);
    if (!n) return;
    const f = el.dataset.field;

    // Type change
    if (f === 'type') {
      const v = el.value;
      if (v === n.type) return;
      const was = CONTAINERS.has(n.type), is = CONTAINERS.has(v);
      if (was && !is && n.children && n.children.length) {
        if (!confirm('Changing to "' + v + '" will remove ' + n.children.length + ' child node(s). Continue?')) {
          el.value = n.type; return;
        }
      }
      n.type = v;
      if (!is) delete n.children;
      renderAll(); return;
    }

    let v;
    if (el.type === 'checkbox') {
      v = el.checked;
    } else if (el.type === 'number') {
      v = el.value === '' ? undefined : parseFloat(el.value);
      // Reject NaN / Infinity so the spec never holds a non-finite number.
      if (v != null && !isFinite(v)) v = undefined;
      // Clamp negatives on size / padding / radius / spacing / typography
      // fields (and weight) so the editor itself can never produce a value
      // outside its own declared range. The displayed value is updated to
      // match the stored one so the form stays internally consistent.
      if (v != null && v < 0 && (NON_NEG_NUMERIC.has(f) || f === 'weight')) {
        v = 0;
        el.value = '0';
      }
      // Alpha is special: 0..1 inclusive. Clamp out-of-range values.
      if (v != null && f === 'alpha' && (v < 0 || v > 1)) {
        v = Math.max(0, Math.min(1, v));
        el.value = String(v);
      }
    } else {
      v = el.value === '' ? undefined : el.value;
    }
    if (v === undefined) delete n[f]; else n[f] = v;

    if (el.dataset.swatch) {
      const sw = el.closest('.lcg-color-row').querySelector('.lcg-swatch');
      if (sw) sw.style.backgroundColor = toCSS(v || '') || 'transparent';
    }
    renderPreview(); updateJSON();
  }
  propsEl.addEventListener('change', onPropChange);
  propsEl.addEventListener('input', e => {
    if (e.target.tagName === 'TEXTAREA' || (e.target.tagName === 'INPUT' && e.target.type === 'text'))
      onPropChange(e);
  });

  // Section toggle (delegated)
  propsEl.addEventListener('click', e => {
    const hd = e.target.closest('[data-sec]');
    if (!hd) return;
    const k = hd.dataset.sec;
    const body = hd.nextElementSibling;
    if (!body) return;
    const open = body.style.display !== 'none';
    body.style.display = open ? 'none' : '';
    S.secState[k] = !open;
    hd.querySelector('.lcg-sec-tog').textContent = open ? '▶' : '▼';
  });

  // JSON buttons
  document.getElementById('lcg-copy-btn').addEventListener('click', () => {
    const v = document.getElementById('lcg-json-out').value;
    if (!v || v.length > 20000) return;
    navigator.clipboard.writeText(v).then(() => {
      const b = document.getElementById('lcg-copy-btn');
      const o = b.textContent; b.textContent = 'Copied!';
      setTimeout(() => { b.textContent = o; }, 1600);
    });
  });
  document.getElementById('lcg-dl-btn').addEventListener('click', () => {
    const v = document.getElementById('lcg-json-out').value;
    if (!v || v.length > 20000) return;
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([v], { type: 'application/json' }));
    a.download = 'layout-card-spec.json';
    a.click(); URL.revokeObjectURL(a.href);
  });

  // Keyboard: Escape closes modals/menus
  document.addEventListener('keydown', e => {
    if (e.key !== 'Escape') return;
    if (!document.getElementById('lcg-import-modal').classList.contains('lcg-modal-off')) closeImportModal();
    if (!document.getElementById('lcg-tpl-modal').classList.contains('lcg-modal-off')) closeTplModal();
    if (!document.getElementById('lcg-cmp-modal').classList.contains('lcg-modal-off')) closeCmpModal();
    if (!document.getElementById('lcg-type-menu').classList.contains('lcg-menu-off')) closeMenu();
  });
}

if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
else init();

})();
</script>
