/* Recognise common component patterns inside an existing spec so the
   tree shows "Image card" rather than "column" for a column whose
   first child is an image and second is a text column. */
function friendlyName(n) {
  if (!n) return '';
  if (n.type === 'text') return 'Text';
  if (n.type === 'image') return 'Image';
  if (n.type === 'markdown') return 'Markdown';
  if (n.type === 'spacer') return 'Spacer';
  if (n.type === 'divider') return 'Divider';
  if (n.type === 'box') {
    const kids = n.children || [];
    if (n.actionUrl && kids.length === 1 && kids[0].type === 'text') return 'Button';
    if (kids.some(c => c.type === 'image') && kids.some(c => c.type === 'column')) return 'Hero card';
    return 'Stack';
  }
  if (n.type === 'column') {
    const kids = n.children || [];
    if (kids.length === 2 && kids[0].type === 'image' && kids[1].type === 'column') return 'Image card';
    if (n.backgroundColor && kids.length >= 2 && kids.every(c => c.type === 'text')) return 'Stat tile';
    if (n.backgroundColor) return 'Card';
    return 'Group';
  }
  if (n.type === 'row') {
    const kids = n.children || [];
    if (kids.length >= 2 && kids.every(c => c.type === 'column')) return 'Tiles row';
    return 'Row';
  }
  return n.type;
}

