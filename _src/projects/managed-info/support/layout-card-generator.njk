/* ── Layout Card Generator ───────────────────────────────── */
#lcg { font-size: 14px; }
/* Visually-hidden label utility for inputs that already have an
   adjacent visible cue (eg. the +/- width slider has a number input
   beside it whose purpose is obvious by sight, but assistive tech
   still needs an associated label). */
.lcg-sr-only {
  position: absolute !important; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
  white-space: nowrap; border: 0;
}

/* Toolbar */
#lcg-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 0 14px; border-bottom: 1px solid var(--light);
  margin-bottom: 14px; flex-wrap: wrap; gap: 8px;
}
.lcg-tb-left, .lcg-tb-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
