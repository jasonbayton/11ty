/* The preview scroll area is the "device wallpaper" the card sits on.
   Defaults to a light wallpaper-like grey; dark preview switches to
   a dark wallpaper. Both are explicit hex so the toggle works
   regardless of the surrounding page theme. */
#lcg-preview-scroll {
  overflow-x: auto; padding: 16px;
  background: #ECECEE; border-radius: 8px;
  border: 1px solid var(--light);
  transition: background .15s ease;
}
#lcg-preview-scroll.lcg-dark-surface { background: #1A1A1C; }
#lcg-phone { margin: 0 auto; transition: width .12s ease; }

/* The card wrapper is the Material 3 surface card the app renders the
   entire layout spec inside on-device. The live app insets every
   element inside the card by ~16dp so content doesn't touch the
   rounded edges - matched here with 16px padding. */
.lcg-card-wrap {
  background: #FFFFFF; padding: 16px;
  border-radius: 24px; overflow: hidden;
  box-sizing: border-box; min-height: 32px;
  font-family: 'Roboto', sans-serif; font-size: 14px;
  box-shadow: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06);
}
/* Compose dp-based padding adds to a node's measured size; mirror
   that with border-box so width/height percentages include padding. */
.lcg-card-wrap, .lcg-card-wrap * { box-sizing: border-box; }
/* Dark preview gives the surface card a dark Material 3 colour. */
.lcg-card-wrap.lcg-dark {
  background: #1F1F22;
  box-shadow: 0 1px 3px rgba(0,0,0,.4), 0 1px 2px rgba(0,0,0,.3);
}
/* The root spec node already has its own backgroundColor (it IS the
   visible card), so the wrapper hides to avoid a second surface and
   drops its own padding so the spec's root takes the full width. */
.lcg-card-wrap.lcg-surface-off {
  background: transparent; box-shadow: none; border-radius: 0;
  overflow: visible; padding: 0;
}

.lcg-card-wrap .lcg-act { cursor: pointer; }
.lcg-card-wrap .lcg-act:hover {
  outline: 2px solid rgba(0,0,0,.15); outline-offset: -2px;
}
.lcg-card-wrap.lcg-dark .lcg-act:hover { outline-color: rgba(255,255,255,.2); }
.lcg-card-wrap .lcg-md p { margin: 0; }
.lcg-card-wrap .lcg-md p + p { margin-top: 4px; }
.lcg-card-wrap .lcg-md ul,
.lcg-card-wrap .lcg-md ol { margin: 2px 0; padding-left: 20px; }
.lcg-prev-empty {
  display: flex; align-items: center; justify-content: center;
  min-height: 80px; color: #aaa; font-size: 13px; font-family: 'Roboto', sans-serif;
}

